---
interface Props {
  title: string;
  url: string;
}
const { title, url } = Astro.props;
const encodedUrl = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
const smsBody = encodeURIComponent(`Check out this land listing: ${title} — ${url}`);
---

<div class="flex flex-wrap gap-3">
  <!-- Facebook -->
  <a
    href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-2 bg-[#1877F2] text-white text-sm font-medium px-4 py-2 rounded-xl hover:opacity-90 transition-opacity"
    aria-label="Share on Facebook"
  >
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
    </svg>
    Facebook
  </a>

  <!-- X / Twitter -->
  <a
    href={`https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-2 bg-black text-white text-sm font-medium px-4 py-2 rounded-xl hover:opacity-90 transition-opacity"
    aria-label="Share on X"
  >
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.73-8.835L1.254 2.25H8.08l4.26 5.632L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
    </svg>
    X
  </a>

  <!-- SMS -->
  <a
    href={`sms:?body=${smsBody}`}
    class="flex items-center gap-2 bg-green-brand text-white text-sm font-medium px-4 py-2 rounded-xl hover:opacity-90 transition-opacity"
    aria-label="Share via SMS"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
    </svg>
    SMS
  </a>

  <!-- Copy Link -->
  <button
    id="copy-link-btn"
    data-url={url}
    class="flex items-center gap-2 bg-gray-100 text-gray-800 text-sm font-medium px-4 py-2 rounded-xl hover:bg-gray-200 transition-colors"
    aria-label="Copy link"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
    </svg>
    <span id="copy-label">Copy Link</span>
  </button>
</div>

<script>
  const btn = document.getElementById('copy-link-btn');
  const label = document.getElementById('copy-label');
  btn?.addEventListener('click', async () => {
    const url = (btn as HTMLButtonElement).dataset.url || window.location.href;
    try {
      await navigator.clipboard.writeText(url);
      if (label) label.textContent = 'Copied!';
      setTimeout(() => { if (label) label.textContent = 'Copy Link'; }, 2000);
    } catch {
      // fallback
    }
  });
</script>
