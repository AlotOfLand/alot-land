---
import { siteConfig } from '../config/site.js';
import { getEntry } from 'astro:content';

const contactSettings = await getEntry('settings', 'contact');
const phone    = contactSettings?.data.phone    ?? siteConfig.phone;
const phoneRaw = contactSettings?.data.phoneRaw ?? siteConfig.phoneRaw;

const currentPath = Astro.url.pathname;

const dropdowns = [
  {
    label: 'Properties',
    links: [
      { label: 'Browse Listings',   href: '/listings',                    desc: 'Available & coming soon parcels' },
      { label: 'Communities',       href: '/communities',                 desc: 'Explore our land communities' },
      { label: 'Sold Properties',   href: '/sold',                        desc: 'Closed deals & buyer stories' },
      { label: 'Preferred Vendors', href: '/resources/preferred-vendors', desc: 'Vetted builders, lenders & excavators' },
    ],
  },
  {
    label: 'Work With Us',
    links: [
      { label: 'Find Land', href: '/find-land', desc: "Tell us what you're looking for" },
      { label: 'Sell Your Land Fast', href: '/sell-land', desc: 'Get a cash offer on your property' },
    ],
  },
  {
    label: 'Company',
    links: [
      { label: 'About Us', href: '/about', desc: 'Our story and mission' },
      { label: 'Team',     href: '/team',  desc: 'Meet the people behind the deals' },
    ],
  },
];

const standaloneLinks = [
  { label: 'Videos',  href: '/videos' },
  { label: 'Contact', href: '/contact' },
];

// Determine if a dropdown is "active" (any child matches current path).
// Exact match, or a true sub-path (so /listings doesn't light up on /listings/favorites
// while still matching /listings/<slug>). Compares the closest (longest) matching link.
function dropdownActive(links: { href: string }[]) {
  return links.some(l => currentPath === l.href || currentPath.startsWith(l.href + '/'));
}
---

<header class="bg-bg-dark border-b border-border-dark sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center flex-shrink-0">
        <img src="/images/alotdotland_hzLogo.png" alt="Alot of Land LLC" class="h-9 w-auto" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-1">

        <!-- Dropdown items -->
        {dropdowns.map((group, i) => (
          <div class="relative dropdown-group">
            <button
              class={`dropdown-trigger flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-lg transition-colors ${
                dropdownActive(group.links) ? 'text-gold' : 'text-gray-300 hover:text-white hover:bg-white/5'
              }`}
              aria-expanded="false"
              data-dropdown={`desktop-${i}`}
            >
              {group.label}
              <svg class="w-3.5 h-3.5 opacity-60 transition-transform dropdown-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>

            <!-- Dropdown panel -->
            <div
              id={`desktop-${i}`}
              class="dropdown-panel absolute top-full left-0 mt-1 w-56 bg-bg-dark border border-border-dark rounded-2xl shadow-xl overflow-hidden opacity-0 invisible translate-y-1 transition-all duration-150"
            >
              {group.links.map(link => (
                <a
                  href={link.href}
                  class={`flex flex-col px-4 py-3 hover:bg-white/5 transition-colors border-b border-border-dark last:border-0 ${
                    currentPath.startsWith(link.href) ? 'text-gold' : 'text-gray-300 hover:text-white'
                  }`}
                >
                  <span class="text-sm font-semibold">{link.label}</span>
                  <span class="text-xs text-gray-500 mt-0.5">{link.desc}</span>
                </a>
              ))}
            </div>
          </div>
        ))}

        <!-- Standalone links -->
        {standaloneLinks.map(link => (
          <a
            href={link.href}
            class={`px-3 py-2 text-sm font-medium rounded-lg transition-colors ${
              currentPath.startsWith(link.href) ? 'text-gold' : 'text-gray-300 hover:text-white hover:bg-white/5'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right side CTAs -->
      <div class="hidden md:flex items-center gap-3">
        <a href={`tel:${phoneRaw}`} class="text-sm text-gray-300 hover:text-white transition-colors font-medium">
          {phone}
        </a>
        <a href="/sell-land" class="border border-gold text-gold text-sm font-bold px-4 py-2 rounded-xl hover:bg-gold hover:text-bg-dark transition-colors">
          Get Cash Offer
        </a>
        <a href="/listings" class="bg-gold text-bg-dark text-sm font-bold px-4 py-2 rounded-xl hover:bg-yellow-400 transition-colors">
          Browse Land
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button id="menu-toggle" class="md:hidden text-gray-300 hover:text-white p-2" aria-label="Toggle menu">
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-border-dark bg-bg-dark">
    <div class="px-4 py-4 space-y-1">

      <!-- Mobile dropdowns as accordions -->
      {dropdowns.map((group, i) => (
        <div class="mobile-accordion">
          <button
            class={`mobile-acc-trigger w-full flex items-center justify-between py-2.5 text-sm font-medium ${
              dropdownActive(group.links) ? 'text-gold' : 'text-gray-300'
            }`}
            data-acc={`mobile-acc-${i}`}
          >
            {group.label}
            <svg class="w-4 h-4 opacity-50 acc-arrow transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div id={`mobile-acc-${i}`} class="hidden pl-3 pb-2 space-y-1 border-l border-border-dark ml-2">
            {group.links.map(link => (
              <a
                href={link.href}
                class={`block py-2 text-sm ${
                  currentPath.startsWith(link.href) ? 'text-gold font-semibold' : 'text-gray-400 hover:text-white'
                }`}
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>
      ))}

      <!-- Standalone mobile links -->
      {standaloneLinks.map(link => (
        <a
          href={link.href}
          class={`block py-2.5 text-sm font-medium ${
            currentPath.startsWith(link.href) ? 'text-gold' : 'text-gray-300 hover:text-white'
          }`}
        >
          {link.label}
        </a>
      ))}

      <!-- Mobile CTAs -->
      <div class="pt-3 border-t border-border-dark space-y-3 mt-2">
        <a href={`tel:${phoneRaw}`} class="block text-gray-300 text-sm font-medium">{phone}</a>
        <a href="/sell-land" class="block border border-gold text-gold text-sm font-bold px-4 py-2.5 rounded-xl text-center">
          Get Cash Offer
        </a>
        <a href="/listings" class="block bg-gold text-bg-dark text-sm font-bold px-4 py-2.5 rounded-xl text-center">
          Browse Land
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {

    // ── Mobile hamburger ──────────────────────────────────
    var toggle   = document.getElementById('menu-toggle');
    var mobileMenu = document.getElementById('mobile-menu');
    var iconOpen = document.getElementById('icon-open');
    var iconClose = document.getElementById('icon-close');

    if (toggle) {
      toggle.addEventListener('click', function () {
        mobileMenu && mobileMenu.classList.toggle('hidden');
        iconOpen  && iconOpen.classList.toggle('hidden');
        iconClose && iconClose.classList.toggle('hidden');
      });
    }

    // ── Mobile accordions ─────────────────────────────────
    document.querySelectorAll('.mobile-acc-trigger').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id = btn.getAttribute('data-acc');
        var panel = document.getElementById(id);
        var arrow = btn.querySelector('.acc-arrow');
        if (!panel) return;
        var isOpen = !panel.classList.contains('hidden');
        // Close all others
        document.querySelectorAll('.mobile-acc-trigger').forEach(function (b) {
          var p = document.getElementById(b.getAttribute('data-acc'));
          var a = b.querySelector('.acc-arrow');
          if (p) p.classList.add('hidden');
          if (a) a.style.transform = '';
        });
        // Toggle this one
        if (!isOpen) {
          panel.classList.remove('hidden');
          if (arrow) arrow.style.transform = 'rotate(180deg)';
        }
      });
    });

    // ── Desktop dropdowns (hover + click) ────────────────
    document.querySelectorAll('.dropdown-group').forEach(function (group) {
      var trigger = group.querySelector('.dropdown-trigger');
      var panel   = group.querySelector('.dropdown-panel');
      var arrow   = group.querySelector('.dropdown-arrow');
      if (!trigger || !panel) return;

      var hoverTimer;

      function openPanel() {
        clearTimeout(hoverTimer);
        panel.classList.remove('opacity-0', 'invisible', 'translate-y-1');
        panel.classList.add('opacity-100', 'visible', 'translate-y-0');
        if (arrow) arrow.style.transform = 'rotate(180deg)';
        trigger.setAttribute('aria-expanded', 'true');
      }

      function closePanel() {
        panel.classList.add('opacity-0', 'invisible', 'translate-y-1');
        panel.classList.remove('opacity-100', 'visible', 'translate-y-0');
        if (arrow) arrow.style.transform = '';
        trigger.setAttribute('aria-expanded', 'false');
      }

      // Hover
      group.addEventListener('mouseenter', openPanel);
      group.addEventListener('mouseleave', function () {
        hoverTimer = setTimeout(closePanel, 120);
      });

      // Click (for touch devices)
      trigger.addEventListener('click', function () {
        var isOpen = panel.classList.contains('opacity-100');
        // Close all dropdowns first
        document.querySelectorAll('.dropdown-panel').forEach(function (p) {
          p.classList.add('opacity-0', 'invisible', 'translate-y-1');
          p.classList.remove('opacity-100', 'visible', 'translate-y-0');
        });
        document.querySelectorAll('.dropdown-arrow').forEach(function (a) {
          a.style.transform = '';
        });
        document.querySelectorAll('.dropdown-trigger').forEach(function (t) {
          t.setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) openPanel();
      });
    });

    // Close all dropdowns when clicking outside
    document.addEventListener('click', function (e) {
      if (!e.target.closest('.dropdown-group')) {
        document.querySelectorAll('.dropdown-panel').forEach(function (p) {
          p.classList.add('opacity-0', 'invisible', 'translate-y-1');
          p.classList.remove('opacity-100', 'visible', 'translate-y-0');
        });
        document.querySelectorAll('.dropdown-arrow').forEach(function (a) {
          a.style.transform = '';
        });
        document.querySelectorAll('.dropdown-trigger').forEach(function (t) {
          t.setAttribute('aria-expanded', 'false');
        });
      }
    });
  });
</script>
