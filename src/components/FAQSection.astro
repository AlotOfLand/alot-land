---
import { getCollection, render } from 'astro:content';

const allFaqs = await getCollection('faqs').catch(() => []);
const faqs = allFaqs
  .filter(f => f.data.active)
  .sort((a, b) => a.data.order - b.data.order);

const buying  = faqs.filter(f => f.data.category === 'buying');
const selling = faqs.filter(f => f.data.category === 'selling');
const general = faqs.filter(f => f.data.category === 'general');

// Render markdown bodies
const rendered = await Promise.all(
  faqs.map(async f => ({ ...f, rendered: await render(f) }))
);
const buyingR  = rendered.filter(f => f.data.category === 'buying');
const sellingR = rendered.filter(f => f.data.category === 'selling');
const generalR = rendered.filter(f => f.data.category === 'general');

if (faqs.length === 0) return;
---

<section class="py-20 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-xs font-bold uppercase tracking-widest text-gold mb-2">Got Questions?</p>
      <h2 class="font-display font-black text-3xl sm:text-4xl text-bg-dark mb-3">Frequently Asked Questions</h2>
      <p class="text-gray-500 max-w-xl mx-auto">Everything you need to know about buying land from us or selling your land to us.</p>
    </div>

    <!-- Two-column layout for buying + selling -->
    <div class="grid md:grid-cols-2 gap-8 md:gap-12">

      <!-- Buying column -->
      {buyingR.length > 0 && (
        <div>
          <div class="flex items-center gap-3 mb-6">
            <span class="text-2xl">🌿</span>
            <h3 class="font-display font-black text-xl text-bg-dark">Buying Land</h3>
          </div>
          <div class="space-y-3" id="faq-buying">
            {buyingR.map((faq, i) => (
              <div class="faq-item border border-gray-100 rounded-2xl overflow-hidden bg-bg-light" data-faq={`buying-${i}`}>
                <button
                  class="faq-trigger w-full flex items-center justify-between gap-4 px-5 py-4 text-left"
                  aria-expanded="false"
                >
                  <span class="font-semibold text-bg-dark text-sm leading-snug">{faq.data.question}</span>
                  <span class="faq-icon flex-shrink-0 w-6 h-6 rounded-full bg-white border border-gray-200 flex items-center justify-center transition-transform">
                    <svg class="w-3 h-3 text-bg-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </span>
                </button>
                <div class="faq-body hidden px-5 pb-5">
                  <div class="text-gray-600 text-sm leading-relaxed prose prose-sm max-w-none">
                    <faq.rendered.Content />
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Selling column -->
      {sellingR.length > 0 && (
        <div>
          <div class="flex items-center gap-3 mb-6">
            <span class="text-2xl">💰</span>
            <h3 class="font-display font-black text-xl text-bg-dark">Selling Your Land</h3>
          </div>
          <div class="space-y-3" id="faq-selling">
            {sellingR.map((faq, i) => (
              <div class="faq-item border border-gray-100 rounded-2xl overflow-hidden bg-bg-light" data-faq={`selling-${i}`}>
                <button
                  class="faq-trigger w-full flex items-center justify-between gap-4 px-5 py-4 text-left"
                  aria-expanded="false"
                >
                  <span class="font-semibold text-bg-dark text-sm leading-snug">{faq.data.question}</span>
                  <span class="faq-icon flex-shrink-0 w-6 h-6 rounded-full bg-white border border-gray-200 flex items-center justify-center transition-transform">
                    <svg class="w-3 h-3 text-bg-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </span>
                </button>
                <div class="faq-body hidden px-5 pb-5">
                  <div class="text-gray-600 text-sm leading-relaxed prose prose-sm max-w-none">
                    <faq.rendered.Content />
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

    </div>

    <!-- General FAQs (full width, if any) -->
    {generalR.length > 0 && (
      <div class="mt-10">
        <div class="flex items-center gap-3 mb-6">
          <span class="text-2xl">💬</span>
          <h3 class="font-display font-black text-xl text-bg-dark">General Questions</h3>
        </div>
        <div class="grid md:grid-cols-2 gap-3">
          {generalR.map((faq, i) => (
            <div class="faq-item border border-gray-100 rounded-2xl overflow-hidden bg-bg-light" data-faq={`general-${i}`}>
              <button
                class="faq-trigger w-full flex items-center justify-between gap-4 px-5 py-4 text-left"
                aria-expanded="false"
              >
                <span class="font-semibold text-bg-dark text-sm leading-snug">{faq.data.question}</span>
                <span class="faq-icon flex-shrink-0 w-6 h-6 rounded-full bg-white border border-gray-200 flex items-center justify-center transition-transform">
                  <svg class="w-3 h-3 text-bg-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
                  </svg>
                </span>
              </button>
              <div class="faq-body hidden px-5 pb-5">
                <div class="text-gray-600 text-sm leading-relaxed prose prose-sm max-w-none">
                  <faq.rendered.Content />
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Bottom CTA -->
    <div class="mt-12 text-center">
      <p class="text-gray-500 text-sm mb-4">Still have questions? We're happy to talk.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/contact" class="bg-gold text-bg-dark font-bold px-6 py-3 rounded-xl hover:bg-yellow-400 transition-colors text-sm">
          Contact Us
        </a>
        <a href="tel:6155386878" class="border border-bg-dark text-bg-dark font-bold px-6 py-3 rounded-xl hover:bg-bg-dark hover:text-white transition-colors text-sm">
          📞 (615) 538-6878
        </a>
      </div>
    </div>

  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.faq-trigger').forEach(function (trigger) {
      trigger.addEventListener('click', function () {
        var item    = trigger.closest('.faq-item');
        var body    = item.querySelector('.faq-body');
        var icon    = item.querySelector('.faq-icon');
        var isOpen  = trigger.getAttribute('aria-expanded') === 'true';

        // Close all siblings in the same container
        var container = item.parentElement;
        container.querySelectorAll('.faq-item').forEach(function (sibling) {
          if (sibling !== item) {
            sibling.querySelector('.faq-body').classList.add('hidden');
            sibling.querySelector('.faq-trigger').setAttribute('aria-expanded', 'false');
            sibling.querySelector('.faq-icon').style.transform = '';
            sibling.classList.remove('border-gold', 'border');
            sibling.classList.add('border-gray-100');
          }
        });

        // Toggle current
        if (isOpen) {
          body.classList.add('hidden');
          trigger.setAttribute('aria-expanded', 'false');
          icon.style.transform = '';
          item.classList.remove('border-gold');
          item.classList.add('border-gray-100');
        } else {
          body.classList.remove('hidden');
          trigger.setAttribute('aria-expanded', 'true');
          icon.style.transform = 'rotate(180deg)';
          item.classList.remove('border-gray-100');
          item.classList.add('border-gold');
        }
      });
    });
  });
</script>
