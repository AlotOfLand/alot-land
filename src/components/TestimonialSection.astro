---
import { getCollection, render } from 'astro:content';

interface Props {
  variant?: 'dark' | 'light';
  max?: number;
}

const { variant = 'dark', max = 3 } = Astro.props;

const allTestimonials = await getCollection('testimonials', t => t.data.featured);
const testimonials = allTestimonials
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, max);

const rendered = await Promise.all(
  testimonials.map(async t => ({
    ...t,
    html: (await render(t)).Content,
  }))
);

const isDark = variant === 'dark';
---

{rendered.length > 0 && (
  <section class={`py-20 ${isDark ? 'bg-bg-dark text-white' : 'bg-bg-light'}`}>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="text-center mb-12">
        <p class={`text-sm font-bold uppercase tracking-widest mb-3 ${isDark ? 'text-gold' : 'text-gold'}`}>
          What Our Clients Say
        </p>
        <h2 class={`font-display font-black text-3xl sm:text-4xl ${isDark ? 'text-white' : 'text-bg-dark'}`}>
          Real People. Real Land. Real Results.
        </h2>
      </div>

      <div class={`grid gap-6 ${rendered.length === 1 ? 'max-w-2xl mx-auto' : rendered.length === 2 ? 'sm:grid-cols-2' : 'sm:grid-cols-2 lg:grid-cols-3'}`}>
        {rendered.map(t => (
          <div class={`rounded-2xl p-8 relative flex flex-col ${isDark ? 'bg-[#111] border border-[#222]' : 'bg-white border border-gray-100 shadow-sm'}`}>
            <!-- Gold quote mark -->
            <div class="text-gold text-6xl font-serif leading-none mb-4 select-none">&ldquo;</div>

            <!-- Quote body -->
            <div class={`text-base leading-relaxed flex-1 mb-6 ${isDark ? 'text-gray-300' : 'text-gray-700'}`}>
              <t.html />
            </div>

            <!-- Attribution -->
            <div class="flex items-center gap-3 pt-4 border-t border-white/10">
              <div class="w-10 h-10 rounded-full bg-gold flex items-center justify-center font-display font-black text-bg-dark text-lg flex-shrink-0">
                {t.data.name.charAt(0)}
              </div>
              <div>
                <p class={`font-semibold text-sm ${isDark ? 'text-white' : 'text-bg-dark'}`}>{t.data.name}</p>
                {(t.data.role || t.data.location) && (
                  <p class="text-text-muted text-xs">
                    {[t.data.role, t.data.location].filter(Boolean).join(' · ')}
                  </p>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
