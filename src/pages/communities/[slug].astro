---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ListingCard from '../../components/ListingCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const communities = await getCollection('communities');
  return communities.map(community => ({
    params: { slug: community.slug },
    props: { community },
  }));
}

const { community } = Astro.props;
const { Content } = await render(community);
const { title, location, status, image } = community.data;

const allListings = await getCollection('listings');
const lots = allListings
  .filter(l => l.data.community === community.slug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const stats = {
  available: lots.filter(l => l.data.status === 'available').length,
  comingSoon: lots.filter(l => l.data.status === 'coming-soon').length,
  sold: lots.filter(l => l.data.status === 'sold').length,
};

const statusLabel: Record<string, string> = {
  'coming-soon': 'Coming Soon',
  'lots-available': 'Lots Available',
  'sold-out': 'Sold Out',
};
const statusColor: Record<string, string> = {
  'coming-soon': 'bg-blue-100 text-blue-700',
  'lots-available': 'bg-green-100 text-green-700',
  'sold-out': 'bg-gray-100 text-gray-500',
};
---

<BaseLayout title={title} description={`Browse lots in ${title}${location ? ` — ${location}` : ''}. A curated community from A Lot of Land LLC.`}>
  <!-- Hero -->
  <div class="relative h-72 sm:h-96 overflow-hidden">
    {image ? (
      <img src={image} alt={title} class="w-full h-full object-cover" />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-bg-dark to-gray-700"></div>
    )}
    <div class="absolute inset-0 bg-black/55"></div>
    <div class="absolute inset-0 flex flex-col items-start justify-end max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
      <a href="/communities" class="text-gray-300 text-sm hover:text-white mb-3 transition-colors">← All Communities</a>
      <div class="flex items-center gap-3 flex-wrap">
        <h1 class="font-display font-black text-4xl sm:text-5xl text-white">{title}</h1>
        <span class={`text-sm font-bold px-3 py-1 rounded-full ${statusColor[status]}`}>
          {statusLabel[status]}
        </span>
      </div>
      {location && (
        <p class="text-gray-300 mt-2 flex items-center gap-1">
          <span>📍</span> {location}
        </p>
      )}
    </div>
  </div>

  <!-- Stats bar -->
  {(stats.available > 0 || stats.comingSoon > 0 || stats.sold > 0) && (
    <div class="bg-white border-b border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-wrap gap-6">
        {stats.available > 0 && (
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-green-500"></span>
            <span class="text-sm font-semibold text-gray-700">{stats.available} Lot{stats.available !== 1 ? 's' : ''} Available</span>
          </div>
        )}
        {stats.comingSoon > 0 && (
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-blue-500"></span>
            <span class="text-sm font-semibold text-gray-700">{stats.comingSoon} Coming Soon</span>
          </div>
        )}
        {stats.sold > 0 && (
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-red-500"></span>
            <span class="text-sm font-semibold text-gray-700">{stats.sold} Sold</span>
          </div>
        )}
      </div>
    </div>
  )}

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Description -->
    <div class="prose prose-gray max-w-3xl mb-12">
      <Content />
    </div>

    <!-- Lots grid -->
    {lots.length > 0 ? (
      <div>
        <h2 class="font-display font-black text-2xl text-bg-dark mb-6">Available Lots</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {lots.map(listing => (
            <ListingCard
              slug={listing.slug}
              title={listing.data.title}
              status={listing.data.status}
              acreage={listing.data.acreage}
              county={listing.data.county}
              state={listing.data.state}
              price={listing.data.price}
              photos={listing.data.photos}
              description={listing.body}
            />
          ))}
        </div>
      </div>
    ) : (
      <div class="text-center py-16 bg-gray-50 rounded-2xl border border-gray-100">
        <p class="text-3xl mb-3">🏗️</p>
        <h3 class="font-display font-bold text-xl text-bg-dark mb-2">Lots Coming Soon</h3>
        <p class="text-gray-500 mb-6">Individual lots for this community will be listed here shortly.</p>
        <a href="/find-land" class="bg-gold text-bg-dark font-bold px-6 py-3 rounded-xl hover:bg-yellow-400 transition-colors">
          Get Notified
        </a>
      </div>
    )}
  </div>
</BaseLayout>
