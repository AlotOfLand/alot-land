---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCommunities = await getCollection('communities');
const sorted = allCommunities.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allListings = await getCollection('listings');

function getStats(communitySlug: string) {
  const lots = allListings.filter(l => l.data.community === communitySlug);
  return {
    available: lots.filter(l => l.data.status === 'available').length,
    comingSoon: lots.filter(l => l.data.status === 'coming-soon').length,
    sold: lots.filter(l => l.data.status === 'sold').length,
    total: lots.length,
  };
}

const statusLabel: Record<string, string> = {
  'coming-soon': 'Coming Soon',
  'lots-available': 'Lots Available',
  'sold-out': 'Sold Out',
};
const statusColor: Record<string, string> = {
  'coming-soon': 'bg-blue-100 text-blue-700',
  'lots-available': 'bg-green-100 text-green-700',
  'sold-out': 'bg-gray-100 text-gray-500',
};
---

<BaseLayout title="Communities" description="Browse land communities and subdivisions from A Lot of Land LLC. Find your lot in one of our curated communities across Arizona, Tennessee, and Arkansas.">
  <div class="bg-bg-dark text-white py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-display font-black text-4xl sm:text-5xl mb-3">Communities</h1>
      <p class="text-gray-400 text-lg">Curated subdivisions with individual lots available for purchase.</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {sorted.length === 0 ? (
      <div class="text-center py-24 bg-white rounded-2xl border border-gray-100">
        <p class="text-4xl mb-4">🏘️</p>
        <h2 class="font-display font-bold text-2xl text-bg-dark mb-3">Communities Coming Soon</h2>
        <p class="text-gray-500 mb-6">We're developing new communities. Check back soon or get on our list.</p>
        <a href="/find-land" class="bg-gold text-bg-dark font-bold px-6 py-3 rounded-xl hover:bg-yellow-400 transition-colors">
          Get Notified
        </a>
      </div>
    ) : (
      <div class="space-y-6">
        {sorted.map(community => {
          const stats = getStats(community.slug);
          const status = community.data.status;
          return (
            <a
              href={`/communities/${community.slug}`}
              class="flex flex-col sm:flex-row bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-md transition-shadow group"
            >
              <!-- Image -->
              <div class="sm:w-80 lg:w-96 flex-shrink-0 relative overflow-hidden">
                {community.data.image ? (
                  <img
                    src={community.data.image}
                    alt={community.data.title}
                    class="w-full h-56 sm:h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                ) : (
                  <div class="w-full h-56 sm:h-full bg-gradient-to-br from-gray-200 to-gray-300 flex items-center justify-center">
                    <span class="text-5xl">🏘️</span>
                  </div>
                )}
                {status === 'sold-out' && (
                  <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
                    <span class="text-white font-black text-3xl tracking-widest rotate-[-15deg] border-4 border-white px-4 py-1 rounded-lg">
                      SOLD OUT
                    </span>
                  </div>
                )}
                {status === 'coming-soon' && (
                  <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
                    <span class="text-blue-300 font-black text-2xl tracking-widest rotate-[-15deg] border-4 border-blue-300 px-4 py-1 rounded-lg">
                      COMING SOON
                    </span>
                  </div>
                )}
              </div>

              <!-- Info -->
              <div class="flex flex-col justify-between p-6 flex-1">
                <div>
                  <div class="flex items-start justify-between gap-4 mb-2">
                    <h2 class="font-display font-black text-2xl text-bg-dark leading-tight">{community.data.title}</h2>
                    <span class={`flex-shrink-0 text-xs font-bold px-3 py-1 rounded-full ${statusColor[status]}`}>
                      {statusLabel[status]}
                    </span>
                  </div>
                  {community.data.location && (
                    <p class="text-text-muted text-sm mb-3 flex items-center gap-1">
                      <span>📍</span> {community.data.location}
                    </p>
                  )}
                </div>

                <!-- Stats -->
                <div class="flex flex-wrap gap-4 mt-4 pt-4 border-t border-gray-100">
                  {stats.available > 0 && (
                    <div class="flex items-center gap-2">
                      <span class="w-3 h-3 rounded-full bg-green-500 flex-shrink-0"></span>
                      <span class="text-sm font-medium text-gray-700">{stats.available} Available</span>
                    </div>
                  )}
                  {stats.comingSoon > 0 && (
                    <div class="flex items-center gap-2">
                      <span class="w-3 h-3 rounded-full bg-blue-500 flex-shrink-0"></span>
                      <span class="text-sm font-medium text-gray-700">{stats.comingSoon} Coming Soon</span>
                    </div>
                  )}
                  {stats.sold > 0 && (
                    <div class="flex items-center gap-2">
                      <span class="w-3 h-3 rounded-full bg-red-500 flex-shrink-0"></span>
                      <span class="text-sm font-medium text-gray-700">{stats.sold} Sold</span>
                    </div>
                  )}
                  {stats.total === 0 && (
                    <span class="text-sm text-gray-400">No lots listed yet</span>
                  )}
                  <span class="ml-auto text-sm font-bold text-gold group-hover:underline">
                    View Community →
                  </span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
</BaseLayout>
