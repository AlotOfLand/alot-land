---
import BaseLayout from '../layouts/BaseLayout.astro';
import ListingCard from '../components/ListingCard.astro';
import VideoEmbed from '../components/VideoEmbed.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import FAQSection from '../components/FAQSection.astro';
import { getCollection, getEntry } from 'astro:content';
import { siteConfig } from '../config/site.js';

const contactSettings  = await getEntry('settings', 'contact');
const homepageSettings = await getEntry('settings', 'homepage');
const phone           = contactSettings?.data.phone           ?? siteConfig.phone;
const phoneRaw        = contactSettings?.data.phoneRaw        ?? siteConfig.phoneRaw;
const homepageVideoId = homepageSettings?.data.homepageVideoId ?? siteConfig.homepageVideoId;
const heroTagline     = homepageSettings?.data.heroTagline     ?? siteConfig.tagline;

const allListings = await getCollection('listings');
const featuredListings = allListings
  .filter(l => l.data.featured && l.data.status === 'available')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative min-h-[85vh] flex items-center justify-center text-white overflow-hidden">
    <img
      src="/images/hero-land.jpg"
      alt="Aerial view of open land at golden hour"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/60"></div>
    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
      <h1 class="font-display font-black text-5xl sm:text-6xl lg:text-7xl mb-6 leading-tight">
        A Lot of Land.
      </h1>
      <p class="text-xl sm:text-2xl text-gray-200 mb-10 max-w-2xl mx-auto leading-relaxed">
        {heroTagline}
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
        <a
          href="/listings"
          class="bg-gold text-bg-dark font-bold text-lg px-8 py-4 rounded-2xl hover:bg-yellow-400 transition-colors"
        >
          Browse Land
        </a>
        <a
          href="/sell-land"
          class="bg-white/15 border border-white/40 text-white font-bold text-lg px-8 py-4 rounded-2xl hover:bg-white/25 transition-colors"
        >
          Sell Your Land
        </a>
      </div>
      <a
        href={`tel:${phoneRaw}`}
        class="inline-flex items-center gap-2 text-gray-300 hover:text-white text-lg transition-colors"
      >
        📞 {phone}
      </a>
    </div>
  </section>

  <!-- What We Do -->
  <section class="py-20 bg-bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        <!-- Buy Land -->
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100 flex flex-col">
          <div class="text-4xl mb-4">🏡</div>
          <h2 class="font-display font-bold text-2xl text-bg-dark mb-3">Buy Land</h2>
          <p class="text-gray-600 leading-relaxed mb-6 flex-1">
            Looking for land? Browse our available properties or tell us exactly what you want and we'll go find it off-market for you.
          </p>
          <div class="flex flex-col gap-3">
            <a href="/listings" class="text-center bg-bg-dark text-white font-semibold px-5 py-2.5 rounded-xl hover:bg-gray-800 transition-colors text-sm">
              View Listings
            </a>
            <a href="/find-land" class="text-center border border-bg-dark text-bg-dark font-semibold px-5 py-2.5 rounded-xl hover:bg-gray-50 transition-colors text-sm">
              Request a Search
            </a>
          </div>
        </div>

        <!-- Sell Land -->
        <div class="bg-green-brand rounded-2xl p-8 text-white flex flex-col">
          <div class="text-4xl mb-4">💵</div>
          <h2 class="font-display font-bold text-2xl mb-3">Sell Your Land</h2>
          <p class="text-green-100 leading-relaxed mb-6 flex-1">
            Want to sell your land fast? We buy land direct — no agent fees, no commissions, no waiting. Get a cash offer within 24 hours.
          </p>
          <div class="flex flex-col gap-3">
            <a href="/sell-land" class="text-center bg-white text-green-brand font-bold px-5 py-2.5 rounded-xl hover:bg-green-50 transition-colors text-sm">
              Get a Cash Offer
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Featured Listings -->
  <section class="py-20 bg-bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-10">
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-bg-dark">Available Now</h2>
        <a href="/listings" class="text-sm font-semibold text-gold hover:underline hidden sm:block">See All Listings →</a>
      </div>

      {featuredListings.length > 0 ? (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredListings.map(listing => (
            <ListingCard
              slug={listing.slug}
              title={listing.data.title}
              status={listing.data.status}
              acreage={listing.data.acreage}
              county={listing.data.county}
              state={listing.data.state}
              price={listing.data.price}
              photos={listing.data.photos}
              description={listing.body}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-16 bg-white rounded-2xl border border-gray-100">
          <p class="text-gray-500 mb-4">New listings coming soon — check back often!</p>
          <a href="/find-land" class="text-gold font-semibold hover:underline">Tell us what you're looking for →</a>
        </div>
      )}

      <div class="text-center mt-10 sm:hidden">
        <a href="/listings" class="text-gold font-semibold hover:underline">See All Listings →</a>
      </div>
    </div>
  </section>

  <!-- Newsletter / New Listings Alert -->
  <section class="py-16 bg-white border-b border-gray-100">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-3xl mb-3">📬</div>
      <h2 class="font-display font-bold text-2xl sm:text-3xl text-bg-dark mb-2">Get New Listings First</h2>
      <p class="text-gray-500 mb-8">Off-market deals in AZ, TN &amp; NW Arkansas. Be the first to know when new parcels drop.</p>
      <form
        name="newsletter"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        id="newsletter-form"
        class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
      >
        <input type="hidden" name="form-name" value="newsletter" />
        <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>
        <label for="newsletter-email" class="sr-only">Email Address</label>
        <input
          id="newsletter-email"
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          class="flex-1 px-4 py-3 rounded-xl border border-gray-200 text-bg-dark text-sm focus:outline-none focus:ring-2 focus:ring-gold"
        />
        <button type="submit" class="bg-gold text-bg-dark font-bold px-6 py-3 rounded-xl hover:bg-yellow-400 transition-colors whitespace-nowrap text-sm">
          Notify Me
        </button>
      </form>
      <div id="newsletter-thanks" class="hidden mt-4">
        <p class="text-green-brand font-semibold">✓ You're on the list! We'll let you know when new deals drop.</p>
      </div>
    </div>
  </section>

  <!-- Operating States -->
  <section class="py-20 bg-bg-dark text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display font-bold text-3xl sm:text-4xl mb-4">Where We Work</h2>
      <p class="text-gray-400 mb-12 text-lg">Active markets — with more on the way.</p>

      <div class="grid sm:grid-cols-3 gap-6 mb-8">
        {[
          { state: 'Arizona', emoji: '🌵', desc: 'Desert land, off-grid parcels, rural homesteads' },
          { state: 'Tennessee', emoji: '🏞️', desc: 'Wooded tracts, hunting land, mountain cabins' },
          { state: 'Northwest Arkansas', emoji: '🌲', desc: 'Ozark foothills, recreational & investment land' },
        ].map(item => (
          <div class="bg-border-dark rounded-2xl p-6 border border-[#333]">
            <div class="text-5xl mb-4">{item.emoji}</div>
            <h3 class="font-display font-bold text-xl mb-2">{item.state}</h3>
            <p class="text-gray-400 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>

      <p class="text-text-muted text-sm">Entering new markets — check back often.</p>
    </div>
  </section>

  <!-- How It Works: Buyer -->
  <section class="py-20 bg-bg-light">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-center text-bg-dark mb-12">
        How It Works — Buying Land
      </h2>
      <div class="grid sm:grid-cols-3 gap-8">
        {[
          { step: '01', icon: '📬', title: 'We Find It Off-Market', desc: 'We reach out directly to landowners through direct mail — not on MLS, not on auction sites.' },
          { step: '02', icon: '📝', title: 'We Get It Under Contract', desc: 'We negotiate directly with the owner and get the property under contract at a fair price.' },
          { step: '03', icon: '🤝', title: 'You Buy It', desc: 'We list the property with top local land realtors. You buy it at a fair, transparent price.' },
        ].map(item => (
          <div class="text-center">
            <div class="w-16 h-16 bg-gold rounded-2xl flex items-center justify-center text-2xl mx-auto mb-4">
              {item.icon}
            </div>
            <div class="text-gold font-bold text-sm mb-2">{item.step}</div>
            <h3 class="font-display font-bold text-lg text-bg-dark mb-2">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/listings" class="bg-bg-dark text-white font-bold px-8 py-4 rounded-2xl hover:bg-gray-800 transition-colors inline-block">
          Browse Available Land
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="py-14 bg-gold">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center text-bg-dark">
        {[
          { stat: '100%', label: 'Off-Market Deals' },
          { stat: '3', label: 'Active States' },
          { stat: 'Direct', label: 'With the Owner' },
        ].map(item => (
          <div>
            <div class="font-display font-black text-4xl mb-1">{item.stat}</div>
            <div class="font-semibold text-sm uppercase tracking-wider">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Video Section -->
  <section class="py-20 bg-bg-light">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-bg-dark mb-4">Hear From David</h2>
      <p class="text-gray-500 mb-8">Watch a quick overview of how we work.</p>
      <div class="aspect-video w-full rounded-2xl overflow-hidden shadow-lg">
        <iframe
          src={`https://www.youtube.com/embed/${homepageVideoId}?rel=0&modestbranding=1`}
          title="A Lot of Land — How We Work"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="w-full h-full"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <TestimonialSection variant="dark" max={3} />

  <!-- FAQ Section -->
  <FAQSection />

  <!-- Bottom CTA -->
  <section class="py-20 bg-bg-dark text-white text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-3xl sm:text-4xl mb-4">Ready to find your land?</h2>
      <p class="text-gray-400 mb-8 text-lg">Browse current listings or reach out and tell us what you're looking for.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/listings" class="bg-gold text-bg-dark font-bold px-8 py-4 rounded-2xl hover:bg-yellow-400 transition-colors">
          Browse Listings
        </a>
        <a href={`tel:${phoneRaw}`} class="border-2 border-white text-white font-bold px-8 py-4 rounded-2xl hover:bg-white/10 transition-colors">
          📞 Call Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const nlForm = document.getElementById('newsletter-form') as HTMLFormElement;
  const nlThanks = document.getElementById('newsletter-thanks');
  const nlBtn = nlForm?.querySelector('button[type="submit"]') as HTMLButtonElement;
  nlForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (nlBtn) { nlBtn.disabled = true; nlBtn.textContent = 'Subscribing…'; }
    try {
      const res = await fetch('/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: new URLSearchParams(new FormData(nlForm) as any).toString() });
      if (!res.ok) throw new Error();
      nlForm.classList.add('hidden');
      nlThanks?.classList.remove('hidden');
    } catch {
      if (nlBtn) { nlBtn.disabled = false; nlBtn.textContent = 'Notify Me'; }
      alert('Something went wrong. Please try again.');
    }
  });
</script>
