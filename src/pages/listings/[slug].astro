---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ListingGallery from '../../components/ListingGallery.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import AmenitySlideshow from '../../components/AmenitySlideshow.astro';
import { getCollection, render } from 'astro:content';
import { siteConfig } from '../../config/site.js';

export async function getStaticPaths() {
  const listings = await getCollection('listings');
  return listings.map(listing => ({
    params: { slug: listing.slug },
    props: { listing },
  }));
}

const { listing } = Astro.props;
const { Content } = await render(listing);
const { title, status, acreage, county, state, price, zoning, roadAccess, water, power, gps, videoUrl, showVideo, zillowUrl, showZillow, photos, amenityPhotos, date, dateSold, showDaysOnMarket, buyerTestimonial, buyerName } = listing.data;

const pageTitle = `${acreage} Acres for Sale${price ? ` — ${price}` : ''} | ${county} County, ${state}`;
const bodyText = listing.body.replace(/[#*_`[\]()>~]/g, '').replace(/\s+/g, ' ').trim();
const pageDescription = `${acreage} acres of land for sale in ${county} County, ${state}${price ? `. Asking ${price}` : ''}. ${bodyText}`.slice(0, 155);
const canonicalUrl = `https://${siteConfig.domain}/listings/${listing.slug}`;
const ogImage = photos[0] || '/images/og-image.jpg';

// Days on Market: only calculated when both dates exist and toggle is on
let daysOnMarket: number | undefined;
if (showDaysOnMarket && date) {
  const end = dateSold ?? new Date();
  daysOnMarket = Math.round((end.getTime() - date.getTime()) / (1000 * 60 * 60 * 24));
}

const details = [
  { label: 'Acreage', value: `${acreage} acres` },
  { label: 'Price', value: price || 'Contact for Price' },
  { label: 'Days on Market', value: daysOnMarket !== undefined ? `${daysOnMarket} days` : undefined },
  { label: 'County', value: county },
  { label: 'State', value: state },
  { label: 'Zoning', value: zoning },
  { label: 'Road Access', value: roadAccess },
  { label: 'Water', value: water },
  { label: 'Power/Utilities', value: power },
];

let mapsUrl: string | undefined;
if (gps) {
  const [lat, lng] = gps.split(',').map(s => s.trim());
  mapsUrl = `https://maps.google.com/?q=${lat},${lng}`;
}
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={ogImage}
  ogType="article"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <!-- Back link -->
    <a href="/listings" class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-bg-dark transition-colors mb-6">
      ← All Listings
    </a>

    <!-- Status badge + Title -->
    <div class="flex items-start gap-4 flex-wrap mb-6">
      <span class={`text-sm font-bold px-3 py-1.5 rounded-full flex-shrink-0 ${
        status === 'available' ? 'bg-green-brand text-white' :
        status === 'coming-soon' ? 'bg-blue-500 text-white' :
        'bg-gray-400 text-white'
      }`}>
        {status === 'available' ? 'Available' : status === 'coming-soon' ? 'Coming Soon' : '🔴 Sold'}
      </span>
      <h1 class="font-display font-black text-3xl sm:text-4xl text-bg-dark leading-tight">
        {title}
      </h1>
    </div>

    <div class="grid lg:grid-cols-3 gap-10">
      <!-- Main content -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Gallery -->
        <ListingGallery photos={photos} title={title} />

        <!-- Video -->
        {showVideo !== false && videoUrl && (
          <div>
            <h2 class="font-display font-bold text-xl text-bg-dark mb-4">Property Video</h2>
            <VideoEmbed url={videoUrl} title={title} />
          </div>
        )}

        <!-- Description -->
        <div class="prose prose-gray max-w-none">
          <h2 class="font-display font-bold text-xl text-bg-dark mb-4">About This Property</h2>
          <Content />
        </div>

        <!-- Share -->
        <ShareButtons title={title} url={canonicalUrl} price={price} acreage={acreage} state={state} />
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Property Details -->
        <div class="bg-white rounded-2xl border border-gray-100 p-6 shadow-sm sticky top-24">
          <h2 class="font-display font-bold text-xl text-bg-dark mb-5">Property Details</h2>
          <dl class="space-y-3">
            {details.filter(d => d.value).map(d => (
              <div class="flex justify-between text-sm gap-4">
                <dt class="text-text-muted font-medium flex-shrink-0">{d.label}</dt>
                <dd class={`text-right font-semibold ${d.label === 'Price' ? 'text-gold' : 'text-bg-dark'}`}>
                  {d.value}
                </dd>
              </div>
            ))}
            {gps && (
              <div class="flex justify-between text-sm gap-4">
                <dt class="text-text-muted font-medium flex-shrink-0">GPS</dt>
                <dd class="text-right">
                  {mapsUrl ? (
                    <a
                      href={mapsUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-gold font-semibold hover:underline"
                    >
                      {gps} ↗
                    </a>
                  ) : (
                    <span class="font-semibold text-bg-dark">{gps}</span>
                  )}
                </dd>
              </div>
            )}
          </dl>

          <!-- Zillow Link -->
          {showZillow && zillowUrl && (
            <div class="mt-5">
              <a
                href={zillowUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-center gap-2 w-full border-2 border-[#006AFF] text-[#006AFF] font-bold py-2.5 rounded-xl hover:bg-[#006AFF] hover:text-white transition-colors text-sm"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 flex-shrink-0">
                  <path d="M12 2L2 9.5V22h7v-7h6v7h7V9.5L12 2z"/>
                </svg>
                View on Zillow ↗
              </a>
            </div>
          )}

          <!-- Inquiry Form -->
          <div class="mt-8 pt-6 border-t border-gray-100">
            <h3 class="font-display font-bold text-lg text-bg-dark mb-4">Inquire About This Property</h3>
            <form
              name="property-inquiry"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              class="space-y-3"
              id="inquiry-form"
            >
              <input type="hidden" name="form-name" value="property-inquiry" />
              <input type="hidden" name="property" value={title} />
              <p class="hidden">
                <label>Don't fill this out: <input name="bot-field" /></label>
              </p>

              <label for="inq-name" class="sr-only">Your Name</label>
              <input
                id="inq-name"
                type="text"
                name="name"
                placeholder="Your Name"
                required
                class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gold"
              />
              <label for="inq-phone" class="sr-only">Phone Number</label>
              <input
                id="inq-phone"
                type="tel"
                name="phone"
                placeholder="Phone Number"
                required
                class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gold"
              />
              <label for="inq-email" class="sr-only">Email Address</label>
              <input
                id="inq-email"
                type="email"
                name="email"
                placeholder="Email Address"
                required
                class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gold"
              />
              <label for="inq-message" class="sr-only">Message</label>
              <textarea
                id="inq-message"
                name="message"
                rows="3"
                placeholder="I'm interested in this property..."
                class="w-full border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-gold resize-none"
              ></textarea>
              <button
                type="submit"
                class="w-full bg-gold text-bg-dark font-bold py-3 rounded-xl hover:bg-yellow-400 transition-colors text-sm"
              >
                Send Inquiry
              </button>
            </form>

            <div id="inquiry-thanks" class="hidden text-center py-4">
              <p class="text-green-brand font-semibold">✓ Message sent! We'll be in touch soon.</p>
            </div>
          </div>
        </div>

        <!-- Buyer Testimonial (sold listings) -->
        {buyerTestimonial && (
          <div class="bg-bg-dark text-white rounded-2xl p-6">
            <div class="text-gold text-4xl font-serif leading-none mb-3 select-none">&ldquo;</div>
            <p class="text-gray-300 text-sm leading-relaxed mb-4">{buyerTestimonial}</p>
            <div class="flex items-center gap-3 pt-3 border-t border-white/10">
              <div class="w-8 h-8 rounded-full bg-gold flex items-center justify-center font-display font-black text-bg-dark text-sm flex-shrink-0">
                {buyerName ? buyerName.charAt(0) : '★'}
              </div>
              <p class="text-white font-semibold text-sm">{buyerName || 'Verified Buyer'}</p>
            </div>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Amenity Slideshow — full width below the property grid -->
  {amenityPhotos && amenityPhotos.length > 0 && (
    <AmenitySlideshow photos={amenityPhotos} heading={`What's Near ${title}`} />
  )}
</BaseLayout>

<script>
  const form = document.getElementById('inquiry-form') as HTMLFormElement;
  const thanks = document.getElementById('inquiry-thanks');

  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Sending…'; }
    try {
      const res = await fetch('/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: new URLSearchParams(new FormData(form) as any).toString() });
      if (!res.ok) throw new Error('Network error');
      form.classList.add('hidden');
      thanks?.classList.remove('hidden');
    } catch {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Send Inquiry'; }
      alert('Something went wrong. Please try again or call us at (423) 370-9888');
    }
  });
</script>
