---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ListingCard from '../../components/ListingCard.astro';
import { getCollection } from 'astro:content';

const allListings = await getCollection('listings');

// URL param-based filtering
const stateFilter = Astro.url.searchParams.get('state') || 'all';
const statusFilter = Astro.url.searchParams.get('status') || 'all';

const filtered = allListings
  .filter(l => {
    const stateOk = stateFilter === 'all' || l.data.state === stateFilter;
    const statusOk = statusFilter === 'all' || l.data.status === statusFilter;
    return stateOk && statusOk;
  })
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const states = ['Arizona', 'Tennessee', 'Northwest Arkansas'];
---

<BaseLayout title="Available Land" description="Browse available land for sale in Arizona, Tennessee, and Northwest Arkansas. Off-market deals direct from A Lot of Land LLC.">
  <div class="bg-bg-dark text-white py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-display font-black text-4xl sm:text-5xl mb-3">Available Land</h1>
      <p class="text-gray-400 text-lg">Off-market parcels across Arizona, Tennessee &amp; Arkansas.</p>
    </div>
  </div>

  <!-- Filter Bar -->
  <div class="bg-white border-b border-gray-200 sticky top-16 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-wrap gap-4 items-center">
      <form method="get" class="flex flex-wrap gap-3 items-center w-full sm:w-auto">
        <!-- State filter -->
        <select
          name="state"
          onchange="this.form.submit()"
          class="border border-gray-200 rounded-xl px-4 py-2 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-gold"
        >
          <option value="all" selected={stateFilter === 'all'}>All States</option>
          {states.map(s => (
            <option value={s} selected={stateFilter === s}>{s}</option>
          ))}
        </select>

        <!-- Status filter -->
        <div class="flex rounded-xl border border-gray-200 overflow-hidden text-sm font-medium">
          {[
            { value: 'all', label: 'All' },
            { value: 'available', label: 'Available' },
            { value: 'sold', label: 'Sold' },
          ].map(opt => (
            <a
              href={`/listings?state=${stateFilter}&status=${opt.value}`}
              class={`px-4 py-2 ${statusFilter === opt.value ? 'bg-bg-dark text-white' : 'text-gray-600 hover:bg-gray-50'}`}
            >
              {opt.label}
            </a>
          ))}
        </div>

        <!-- Hidden status input so form submit carries it -->
        <input type="hidden" name="status" value={statusFilter} />
      </form>

      <span class="text-sm text-text-muted ml-auto">{filtered.length} listing{filtered.length !== 1 ? 's' : ''}</span>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {filtered.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {filtered.map(listing => (
          <ListingCard
            slug={listing.slug}
            title={listing.data.title}
            status={listing.data.status}
            acreage={listing.data.acreage}
            county={listing.data.county}
            state={listing.data.state}
            price={listing.data.price}
            photos={listing.data.photos}
            description={listing.body}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-20 bg-white rounded-2xl border border-gray-100">
        <p class="text-2xl mb-3">🗺️</p>
        <h3 class="font-display font-bold text-xl text-bg-dark mb-2">No listings in this area yet</h3>
        <p class="text-gray-500 mb-6">Check back soon or tell us exactly what you're looking for.</p>
        <a href="/find-land" class="bg-gold text-bg-dark font-bold px-6 py-3 rounded-xl hover:bg-yellow-400 transition-colors">
          Request a Custom Search
        </a>
      </div>
    )}
  </div>
</BaseLayout>
