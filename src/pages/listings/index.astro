---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ListingCard from '../../components/ListingCard.astro';
import { getCollection } from 'astro:content';

const allListings = await getCollection('listings');
const sorted = allListings.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const states = ['Arizona', 'Tennessee', 'Northwest Arkansas'];

const mapListings = sorted
  .filter(l => l.data.lat && l.data.lng)
  .map(l => ({
    slug: l.slug,
    title: l.data.title,
    status: l.data.status,
    state: l.data.state,
    acreage: l.data.acreage,
    price: l.data.price || 'Contact for Price',
    lat: l.data.lat,
    lng: l.data.lng,
    photo: l.data.photos[0] || '',
  }));
---

<BaseLayout title="Available Land" description="Browse available land for sale in Arizona, Tennessee, and Northwest Arkansas. Off-market deals direct from A Lot of Land LLC.">
  <link slot="head" rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <div class="bg-bg-dark text-white py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-display font-black text-4xl sm:text-5xl mb-3">Available Land</h1>
      <p class="text-gray-400 text-lg">Off-market parcels across Arizona, Tennessee &amp; Arkansas.</p>
    </div>
  </div>

  <!-- Filter Bar -->
  <div class="bg-white border-b border-gray-200 sticky top-16 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-wrap gap-3 items-center">

      <!-- State filter -->
      <select id="filter-state" class="border border-gray-200 rounded-xl px-4 py-2 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-gold">
        <option value="all">All States</option>
        {states.map(s => <option value={s}>{s}</option>)}
      </select>

      <!-- Status filter -->
      <div class="flex rounded-xl border border-gray-200 overflow-hidden text-sm font-medium">
        {[
          { value: 'all', label: 'All' },
          { value: 'available', label: 'Available' },
          { value: 'coming-soon', label: 'Coming Soon' },
          { value: 'sold', label: 'Sold' },
        ].map(opt => (
          <button class="status-btn px-4 py-2 transition-colors" data-status={opt.value}>{opt.label}</button>
        ))}
      </div>

      <span id="listing-count" class="text-sm text-text-muted"></span>

      <!-- View toggles -->
      <div class="ml-auto flex gap-2">
        <button id="toggle-map" class="flex items-center gap-1.5 border border-gray-200 rounded-xl px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
          <span id="toggle-map-label">Hide Map</span>
        </button>
        <button id="toggle-grid" class="flex items-center gap-1.5 border border-gray-200 rounded-xl px-4 py-2 text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 16 16">
            <rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/>
            <rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/>
          </svg>
          <span id="toggle-grid-label">Hide Grid</span>
        </button>
      </div>
    </div>
  </div>

  <!-- MAP (bounded box, shown by default) -->
  <div id="map-section" class="border-b border-gray-200 relative">
    <div id="map" style="height: 420px; width: 100%;"></div>
    <!-- Legend -->
    <div class="absolute bottom-4 right-4 z-[1000] bg-white rounded-xl shadow border border-gray-100 px-3 py-2 text-xs font-medium space-y-1.5">
      <div class="flex items-center gap-2">
        <svg width="12" height="18" viewBox="0 0 12 18"><path d="M6 0C2.686 0 0 2.686 0 6c0 4.5 6 12 6 12s6-7.5 6-12C12 2.686 9.314 0 6 0z" fill="#3CB054"/><circle cx="6" cy="6" r="2.5" fill="white"/></svg>
        Available
      </div>
      <div class="flex items-center gap-2">
        <svg width="12" height="18" viewBox="0 0 12 18"><path d="M6 0C2.686 0 0 2.686 0 6c0 4.5 6 12 6 12s6-7.5 6-12C12 2.686 9.314 0 6 0z" fill="#3B82F6"/><circle cx="6" cy="6" r="2.5" fill="white"/></svg>
        Coming Soon
      </div>
      <div class="flex items-center gap-2">
        <svg width="12" height="18" viewBox="0 0 12 18"><path d="M6 0C2.686 0 0 2.686 0 6c0 4.5 6 12 6 12s6-7.5 6-12C12 2.686 9.314 0 6 0z" fill="#DC2626"/><circle cx="6" cy="6" r="2.5" fill="white"/></svg>
        Sold
      </div>
    </div>
  </div>

  <!-- GRID -->
  <div id="grid-section" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div id="listings-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {sorted.map(listing => (
        <div class="listing-item" data-state={listing.data.state} data-status={listing.data.status}>
          <ListingCard
            slug={listing.slug}
            title={listing.data.title}
            status={listing.data.status}
            acreage={listing.data.acreage}
            county={listing.data.county}
            state={listing.data.state}
            price={listing.data.price}
            photos={listing.data.photos}
            description={listing.body}
          />
        </div>
      ))}
    </div>

    <div id="no-results" class="hidden text-center py-20 bg-white rounded-2xl border border-gray-100">
      <p class="text-2xl mb-3">🗺️</p>
      <h3 class="font-display font-bold text-xl text-bg-dark mb-2">No listings match this filter</h3>
      <p class="text-gray-500 mb-6">Try a different state or check back soon.</p>
      <a href="/find-land" class="bg-gold text-bg-dark font-bold px-6 py-3 rounded-xl hover:bg-yellow-400 transition-colors">
        Request a Custom Search
      </a>
    </div>
  </div>

  <script type="application/json" id="map-data" set:html={JSON.stringify(mapListings)}></script>
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var activeState  = 'all';
      var activeStatus = 'all';
      var mapVisible   = true;
      var gridVisible  = true;
      var map          = null;
      var markers      = [];

      var stateSelect     = document.getElementById('filter-state');
      var statusBtns      = document.querySelectorAll('.status-btn');
      var gridItems       = document.querySelectorAll('.listing-item');
      var noResults       = document.getElementById('no-results');
      var countEl         = document.getElementById('listing-count');
      var mapSection      = document.getElementById('map-section');
      var gridSection     = document.getElementById('grid-section');
      var btnToggleMap    = document.getElementById('toggle-map');
      var btnToggleGrid   = document.getElementById('toggle-grid');
      var labelMap        = document.getElementById('toggle-map-label');
      var labelGrid       = document.getElementById('toggle-grid-label');

      // ── Custom pins ──────────────────────────────────────
      function makeIcon(color) {
        return L.divIcon({
          className: '',
          html: '<svg width="22" height="32" viewBox="0 0 22 32" xmlns="http://www.w3.org/2000/svg">' +
                '<path d="M11 0C4.925 0 0 4.925 0 11c0 7.667 11 21 11 21s11-13.333 11-21C22 4.925 17.075 0 11 0z" fill="' + color + '" stroke="white" stroke-width="1.5"/>' +
                '<circle cx="11" cy="11" r="4.5" fill="white"/></svg>',
          iconSize: [22, 32],
          iconAnchor: [11, 32],
          popupAnchor: [0, -34],
        });
      }
      var iconGreen = makeIcon('#3CB054');
      var iconRed   = makeIcon('#DC2626');
      var iconBlue  = makeIcon('#3B82F6');

      // ── Init map ─────────────────────────────────────────
      function initMap() {
        if (map) return;
        map = L.map('map').setView([38.5, -96], 4);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
          maxZoom: 18,
        }).addTo(map);

        var raw = document.getElementById('map-data');
        if (!raw) return;
        JSON.parse(raw.textContent || '[]').forEach(function (l) {
          var popup =
            '<div style="min-width:180px;font-family:sans-serif;">' +
            (l.photo ? '<img src="' + l.photo + '" style="width:100%;height:100px;object-fit:cover;border-radius:8px;margin-bottom:8px;"/>' : '') +
            '<div style="font-weight:700;font-size:14px;margin-bottom:4px;">' + l.title + '</div>' +
            '<div style="font-size:12px;color:#888;margin-bottom:6px;">' + l.acreage + ' acres · ' + l.state + '</div>' +
            '<div style="font-weight:700;color:' + (l.status === 'available' ? '#F5B800' : l.status === 'coming-soon' ? '#3B82F6' : '#888') + ';margin-bottom:10px;">' +
              (l.status === 'available' ? l.price : l.status === 'coming-soon' ? '🔵 Coming Soon' : '🔴 SOLD') + '</div>' +
            '<a href="/listings/' + l.slug + '" style="display:block;background:#0A0A0A;color:#fff;text-align:center;padding:7px;border-radius:8px;font-size:12px;font-weight:700;text-decoration:none;">View Details →</a>' +
            '</div>';
          var icon = l.status === 'available' ? iconGreen : l.status === 'coming-soon' ? iconBlue : iconRed;
          var m = L.marker([l.lat, l.lng], { icon: icon }).bindPopup(popup);
          m.addTo(map);
          markers.push({ marker: m, state: l.state, status: l.status });
        });
      }

      // ── Apply filters ─────────────────────────────────────
      function applyFilters() {
        var visible = 0;
        gridItems.forEach(function (item) {
          var show = (activeState === 'all' || item.getAttribute('data-state') === activeState) &&
                     (activeStatus === 'all' || item.getAttribute('data-status') === activeStatus);
          item.style.display = show ? '' : 'none';
          if (show) visible++;
        });
        if (noResults) noResults.classList.toggle('hidden', visible > 0);
        if (countEl) countEl.textContent = visible + ' listing' + (visible !== 1 ? 's' : '');

        if (map) {
          markers.forEach(function (m) {
            var show = (activeState === 'all' || m.state === activeState) &&
                       (activeStatus === 'all' || m.status === activeStatus);
            show ? m.marker.addTo(map) : m.marker.remove();
          });
        }

        statusBtns.forEach(function (btn) {
          btn.className = 'status-btn px-4 py-2 transition-colors ' +
            (btn.getAttribute('data-status') === activeStatus ? 'bg-bg-dark text-white' : 'text-gray-600 hover:bg-gray-50');
        });
      }

      // ── Toggle map ────────────────────────────────────────
      function toggleMap() {
        mapVisible = !mapVisible;
        mapSection.classList.toggle('hidden', !mapVisible);
        labelMap.textContent = mapVisible ? 'Hide Map' : 'Show Map';
        btnToggleMap.classList.toggle('bg-gray-100', !mapVisible);
        if (mapVisible) {
          initMap();
          setTimeout(function () { if (map) map.invalidateSize(); }, 50);
        }
      }

      // ── Toggle grid ───────────────────────────────────────
      function toggleGrid() {
        gridVisible = !gridVisible;
        gridSection.classList.toggle('hidden', !gridVisible);
        labelGrid.textContent = gridVisible ? 'Hide Grid' : 'Show Grid';
        btnToggleGrid.classList.toggle('bg-gray-100', !gridVisible);
      }

      // ── Events ────────────────────────────────────────────
      if (stateSelect) stateSelect.addEventListener('change', function () { activeState = stateSelect.value; applyFilters(); });
      statusBtns.forEach(function (btn) { btn.addEventListener('click', function () { activeStatus = btn.getAttribute('data-status'); applyFilters(); }); });
      if (btnToggleMap)  btnToggleMap.addEventListener('click',  toggleMap);
      if (btnToggleGrid) btnToggleGrid.addEventListener('click', toggleGrid);

      // ── Boot ──────────────────────────────────────────────
      initMap();
      applyFilters();
    });
  </script>
</BaseLayout>
