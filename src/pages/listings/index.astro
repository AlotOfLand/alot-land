---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ListingCard from '../../components/ListingCard.astro';
import { getCollection } from 'astro:content';

const allListings = await getCollection('listings');
const sorted = allListings.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const states = ['Arizona', 'Tennessee', 'Northwest Arkansas'];
---

<BaseLayout title="Available Land" description="Browse available land for sale in Arizona, Tennessee, and Northwest Arkansas. Off-market deals direct from A Lot of Land LLC.">
  <div class="bg-bg-dark text-white py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-display font-black text-4xl sm:text-5xl mb-3">Available Land</h1>
      <p class="text-gray-400 text-lg">Off-market parcels across Arizona, Tennessee &amp; Arkansas.</p>
    </div>
  </div>

  <!-- Filter Bar -->
  <div class="bg-white border-b border-gray-200 sticky top-16 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-wrap gap-4 items-center">

      <!-- State filter -->
      <select
        id="filter-state"
        class="border border-gray-200 rounded-xl px-4 py-2 text-sm font-medium bg-white focus:outline-none focus:ring-2 focus:ring-gold"
      >
        <option value="all">All States</option>
        {states.map(s => (
          <option value={s}>{s}</option>
        ))}
      </select>

      <!-- Status filter -->
      <div class="flex rounded-xl border border-gray-200 overflow-hidden text-sm font-medium">
        {[
          { value: 'all', label: 'All' },
          { value: 'available', label: 'Available' },
          { value: 'sold', label: 'Sold' },
        ].map(opt => (
          <button
            class="status-btn px-4 py-2 transition-colors"
            data-status={opt.value}
          >
            {opt.label}
          </button>
        ))}
      </div>

      <span id="listing-count" class="text-sm text-text-muted ml-auto"></span>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- All listings rendered, filtered via JS -->
    <div id="listings-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {sorted.map(listing => (
        <div
          class="listing-item"
          data-state={listing.data.state}
          data-status={listing.data.status}
        >
          <ListingCard
            slug={listing.slug}
            title={listing.data.title}
            status={listing.data.status}
            acreage={listing.data.acreage}
            county={listing.data.county}
            state={listing.data.state}
            price={listing.data.price}
            photos={listing.data.photos}
            description={listing.body}
          />
        </div>
      ))}
    </div>

    <!-- Empty state -->
    <div id="no-results" class="hidden text-center py-20 bg-white rounded-2xl border border-gray-100">
      <p class="text-2xl mb-3">🗺️</p>
      <h3 class="font-display font-bold text-xl text-bg-dark mb-2">No listings match this filter</h3>
      <p class="text-gray-500 mb-6">Try a different state or check back soon for new properties.</p>
      <a href="/find-land" class="bg-gold text-bg-dark font-bold px-6 py-3 rounded-xl hover:bg-yellow-400 transition-colors">
        Request a Custom Search
      </a>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var stateSelect = document.getElementById('filter-state');
    var statusBtns = document.querySelectorAll('.status-btn');
    var items = document.querySelectorAll('.listing-item');
    var noResults = document.getElementById('no-results');
    var countEl = document.getElementById('listing-count');

    var activeState = 'all';
    var activeStatus = 'all';

    // Read URL params on load
    var params = new URLSearchParams(window.location.search);
    if (params.get('state')) activeState = params.get('state');
    if (params.get('status')) activeStatus = params.get('status');

    // Set initial select value
    if (stateSelect) stateSelect.value = activeState;

    function applyFilters() {
      var visible = 0;

      items.forEach(function (item) {
        var itemState = item.getAttribute('data-state');
        var itemStatus = item.getAttribute('data-status');
        var stateOk = activeState === 'all' || itemState === activeState;
        var statusOk = activeStatus === 'all' || itemStatus === activeStatus;

        if (stateOk && statusOk) {
          item.style.display = '';
          visible++;
        } else {
          item.style.display = 'none';
        }
      });

      // Count
      if (countEl) countEl.textContent = visible + ' listing' + (visible !== 1 ? 's' : '');

      // Empty state
      if (noResults) noResults.classList.toggle('hidden', visible > 0);

      // Update status button styles
      statusBtns.forEach(function (btn) {
        var isActive = btn.getAttribute('data-status') === activeStatus;
        btn.className = 'status-btn px-4 py-2 transition-colors ' + (isActive ? 'bg-bg-dark text-white' : 'text-gray-600 hover:bg-gray-50');
      });

      // Update URL without reload
      var url = new URL(window.location.href);
      if (activeState !== 'all') { url.searchParams.set('state', activeState); } else { url.searchParams.delete('state'); }
      if (activeStatus !== 'all') { url.searchParams.set('status', activeStatus); } else { url.searchParams.delete('status'); }
      window.history.replaceState({}, '', url);
    }

    // State filter
    if (stateSelect) {
      stateSelect.addEventListener('change', function () {
        activeState = stateSelect.value;
        applyFilters();
      });
    }

    // Status filter
    statusBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        activeStatus = btn.getAttribute('data-status');
        applyFilters();
      });
    });

    // Run on load
    applyFilters();
  });
</script>
