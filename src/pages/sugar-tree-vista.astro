---
/*  SUGAR TREE VISTA — sales / landing page (standalone, hardcoded Phase 1)
    Lot cards pull from the listings collection (community: sugar-tree-vista).
    Things-to-do map = free Leaflet/OSM + Google deep-links (no Maps billing).
    Countdown + hero video read from CMS settings/sugar-tree.json.
    PLACEHOLDERS still to wire (search "TODO"): photos, hero video, GHL
    showing/consult calendars, gated area-guide form, VERIFIED drive times. */
import { getCollection, getEntry } from 'astro:content';
import { siteConfig } from '../config/site.js';

const GA = siteConfig.analytics.gaMeasurementId; // reuse existing GA4
const phoneRaw = '6155386878';
const phoneDisp = '(615) 538-6878';

const st = await getEntry('settings', 'sugar-tree');
const saleDate = st?.data.saleDate ?? '2026-08-01T09:00:00.000-05:00';
const heroVideoUrl = st?.data.heroVideoUrl ?? '';
const heroImage = st?.data.heroImage ?? '';
const guidePhoto = st?.data.guidePhoto ?? '';
const developerPhoto = st?.data.developerPhoto ?? '';
const galleryPhotos = st?.data.galleryPhotos ?? [];
const ogImageRaw = st?.data.ogImage ?? '';
const ogImageUrl = ogImageRaw
  ? (ogImageRaw.startsWith('http') ? ogImageRaw : `https://alot.land${ogImageRaw}`)
  : 'https://alot.land/images/OG_Social_Image.jpg';

// ── Lots (from the backend, filtered to this community) ──────────────────────
const lotNum = (l: any) => { const m = l.data.title.match(/Lot\s+(\d+)/i); return m ? +m[1] : 999; };
const lotEntries = (await getCollection('listings'))
  .filter(l => l.data.community === 'sugar-tree-vista')
  .sort((a, b) => lotNum(a) - lotNum(b));

const lots = lotEntries.map(l => ({
  slug: l.slug,
  num: lotNum(l),
  name: l.data.title.replace(/^Lot\s+\d+\s*[—-]\s*/i, '').trim(),
  acreage: l.data.acreage,
  price: l.data.price || 'Contact for Price',
  status: l.data.status,
  photo: l.data.photos[0] || '',
  desc: (l.body.split('\n').map(s => s.trim()).find(Boolean) || ''),
}));

// ── Shared images ────────────────────────────────────────────────────────────
// The community entry supplies the "selected" community image; fall back so
// nothing is ever a blank placeholder.
const community = await getEntry('communities', 'sugar-tree-vista');
const lotPhotoPool = lotEntries.flatMap(l => l.data.photos ?? []);
const firstAmenity = community?.data.amenityPhotos?.[0]?.image ?? '';
// "The property" pin panel in the Explore-the-Area map:
const propImage = community?.data.image || heroImage || lotPhotoPool[0] || firstAmenity || '';
// Property Photos gallery: use curated Gallery Photos from Settings if set,
// otherwise fall back to the lot photos already uploaded on the listings.
const gallery = (galleryPhotos.length > 0 ? galleryPhotos : lotPhotoPool).slice(0, 12);

// Lot-map pins — only lots that already have GPS (David adds these in the CMS)
function parseGps(g?: string) {
  if (!g) return null;
  const [a, b] = g.split(',').map(s => parseFloat(s.trim()));
  return (Number.isNaN(a) || Number.isNaN(b)) ? null : { lat: a, lng: b };
}
const lotPins = lotEntries.map(l => {
  const c = parseGps(l.data.gps);
  return c ? { slug: l.slug, name: l.data.title, status: l.data.status, price: l.data.price || '', acreage: l.data.acreage, lat: c.lat, lng: c.lng } : null;
}).filter(Boolean);

const statusPill: Record<string, string> = {
  'available': 'Available', 'coming-soon': 'Coming Soon', 'under-contract': 'Under Contract', 'sold': 'Sold',
};

// ── Drive times — PLACEHOLDERS (David verifying; he drove Parsons = 22 min) ──
const drives = [
  { t: '~8 min', p: 'The Ponderosa boat launch — Tennessee River / Kentucky Lake' },
  { t: '20 min', p: 'Natchez Trace State Park' },
  { t: '22 min', p: 'Parsons, TN — daily supplies' },
  { t: '45 min', p: 'Jackson, TN — dining & nightlife' },
  { t: '90 min', p: 'Nashville' },
];
---

<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Sugar Tree Vista — Ridgeline View Acreage near Kentucky Lake | Alot Of Land LLC</title>
<meta name="description" content="Ten unrestricted ridgeline homesites, 5.4–11.4 acres, above Kentucky Lake in Decatur County, TN. Driveways in, septic soil maps included. Owner financing. From $59,000." />
<link rel="canonical" href="https://alot.land/sugar-tree-vista" />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Alot Of Land LLC" />
<meta property="og:title" content="Sugar Tree Vista — Ridgeline View Acreage near Kentucky Lake" />
<meta property="og:description" content="Ten unrestricted ridgeline homesites, 5.4–11.4 acres, above Kentucky Lake in Decatur County, TN. From $59,000." />
<meta property="og:url" content="https://alot.land/sugar-tree-vista" />
<meta property="og:image" content={ogImageUrl} />
<meta name="twitter:card" content="summary_large_image" />

<link rel="icon" type="image/png" href="/sugar-tree-logo.png" />

<!-- GA4 (reuses the site's existing property) -->
<script async src={`https://www.googletagmanager.com/gtag/js?id=${GA}`}></script>
<script is:inline define:vars={{ GA }}>
  window.dataLayer = window.dataLayer || [];
  function gtag(){ dataLayer.push(arguments); }
  gtag('js', new Date());
  gtag('config', GA);
  window.__gtag = gtag;
</script>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

<!-- Leaflet (free OpenStreetMap maps — no API key, no billing) -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<!-- is:global so styles also reach the map panel content injected at runtime by JS
     (Astro scopes <style> to build-time elements only). Page is standalone, so global is page-local. -->
<style is:global>
  :root{
    --pine:#0a1628; --pine-2:#13294d; --moss:#3b55a3; --meadow:#f5b800;
    --meadow-soft:#ffd76b; --gold-ink:#8f6e00; --river:#34508f;
    --paper:#f2f4f8; --paper-2:#e6ecf4; --ink:#0e1a2e; --ink-soft:#48566f;
    --line:rgba(10,22,40,.13); --maxw:1180px; --r:14px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{font-family:"DM Sans",system-ui,sans-serif;color:var(--ink);background:var(--paper);line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
  h1,h2,h3,h4{font-family:"Fraunces",Georgia,serif;line-height:1.05;font-weight:600;letter-spacing:-.01em}
  .mono{font-family:"DM Mono",monospace}
  .eyebrow{font-family:"DM Mono",monospace;text-transform:uppercase;letter-spacing:.24em;font-size:.72rem;font-weight:500;color:var(--gold-ink)}
  .hero .eyebrow,.purchase .eyebrow,.final .eyebrow{color:var(--meadow-soft)}
  a{color:inherit;text-decoration:none}
  img{max-width:100%;display:block}
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 22px}
  section{position:relative}
  .topo{position:absolute;inset:0;pointer-events:none;opacity:.5;z-index:0}
  .topo svg{width:100%;height:100%}
  .topo path{fill:none;stroke:rgba(255,255,255,.10);stroke-width:1.2}

  .btn{display:inline-flex;align-items:center;gap:.5em;font-family:"DM Mono",monospace;font-weight:500;letter-spacing:.04em;font-size:.82rem;text-transform:uppercase;padding:15px 26px;border-radius:999px;border:1.5px solid transparent;cursor:pointer;transition:transform .18s,background .18s,color .18s}
  .btn-primary{background:var(--meadow);color:var(--pine)}
  .btn-primary:hover{transform:translateY(-2px);background:var(--meadow-soft)}
  .btn-ghost{border-color:rgba(255,255,255,.45);color:#fff}
  .btn-ghost:hover{background:rgba(255,255,255,.1);transform:translateY(-2px)}
  .btn-dark{background:var(--pine);color:var(--paper)}
  .btn-dark:hover{transform:translateY(-2px);background:var(--pine-2)}

  .utility{background:var(--pine);color:rgba(255,255,255,.82);font-size:.8rem}
  .utility .wrap{display:flex;justify-content:space-between;align-items:center;gap:14px;padding:9px 22px;flex-wrap:wrap}
  .utility a:hover{color:#fff}
  .utility .right{display:flex;gap:18px;align-items:center}

  header.nav{position:sticky;top:0;z-index:50;background:rgba(242,244,248,.92);backdrop-filter:blur(10px);border-bottom:1px solid var(--line)}
  .nav .wrap{display:flex;align-items:center;justify-content:space-between;padding-top:14px;padding-bottom:14px}
  .brand{font-family:"Fraunces";font-weight:600;font-size:1.18rem;letter-spacing:-.02em;display:flex;align-items:center;gap:10px}
  .brand .mark{width:36px;height:36px;flex:none;border-radius:50%;background:url("/sugar-tree-logo.png") center/cover;box-shadow:0 1px 3px rgba(10,22,40,.18)}
  nav ul{display:flex;gap:24px;list-style:none;font-size:.86rem;font-weight:500}
  nav a:hover{color:var(--meadow)}
  .menu-toggle{display:none;background:none;border:1.5px solid var(--line);border-radius:10px;padding:8px 11px;font-size:1.1rem;cursor:pointer}

  .event-bar{background:var(--meadow);color:var(--pine);padding:10px 0;font-family:"DM Mono",monospace}
  .eb-wrap{display:flex;align-items:center;justify-content:space-between;gap:12px 18px;flex-wrap:wrap}
  .eb-points{list-style:none;display:flex;flex-wrap:wrap;gap:6px 18px;font-size:.78rem;font-weight:500;text-transform:uppercase;letter-spacing:.05em}
  .eb-points li{position:relative;padding-left:15px}
  .eb-points li::before{content:"•";position:absolute;left:0;opacity:.65}
  .countdown{display:inline-flex;gap:11px;font-weight:500;background:var(--moss);color:var(--meadow);padding:7px 15px;border-radius:999px;flex:none}
  .countdown b{color:var(--meadow)}
  .countdown span small{display:block;font-size:.6rem;letter-spacing:.18em;color:rgba(255,255,255,.72);text-transform:uppercase}
  @media(max-width:640px){.eb-wrap{justify-content:center}.eb-points{justify-content:center;text-align:center}}

  .hero{background:linear-gradient(180deg,#0a1628,#122a4d 60%,#1c3a6b);color:var(--paper);padding:74px 0 70px;overflow:hidden}
  .hero .wrap{position:relative;z-index:2}
  .hero h1{font-size:clamp(2.4rem,6.4vw,4.6rem);font-weight:600;color:#fff}
  .hero h1 em{font-style:italic;color:var(--meadow-soft)}
  .hero .sub{font-size:clamp(1.05rem,2.2vw,1.4rem);font-family:"Fraunces";font-weight:400;color:rgba(255,255,255,.85);max-width:620px;margin-top:14px}
  .hero .stats{display:flex;gap:30px;flex-wrap:wrap;margin:26px 0 30px}
  .hero .stat .n{font-family:"DM Mono";font-size:1.7rem;font-weight:500;color:var(--meadow-soft)}
  .hero .stat .l{font-size:.78rem;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.6)}
  .hero .cta-row{display:flex;gap:14px;flex-wrap:wrap}
  .promo-pill{display:inline-flex;align-items:center;gap:.6em;margin-top:18px;background:rgba(255,255,255,.08);border:1px solid var(--meadow-soft);color:#fff;font-family:"DM Mono";font-size:.82rem;padding:10px 16px;border-radius:999px;max-width:520px}
  .promo-pill b{color:var(--meadow-soft);font-weight:500}
  .video-frame{margin-top:38px;border-radius:var(--r);overflow:hidden;border:1px solid rgba(255,255,255,.18);aspect-ratio:16/9;background:#081020;position:relative;display:flex;align-items:center;justify-content:center}
  .video-frame iframe{width:100%;height:100%;border:0}
  .video-frame .play{width:74px;height:74px;border-radius:50%;background:var(--meadow);color:var(--pine);display:flex;align-items:center;justify-content:center;font-size:1.6rem}
  .video-frame .ph{position:absolute;bottom:14px;left:16px;font-family:"DM Mono";font-size:.7rem;color:rgba(255,255,255,.5)}

  .guide{background:var(--paper-2);padding:64px 0;border-bottom:1px solid var(--line)}
  .guide .grid{display:grid;grid-template-columns:200px 1fr;gap:36px;align-items:center;margin-top:18px}
  .guide .photo{width:200px;height:200px;border-radius:var(--r);background:linear-gradient(135deg,var(--moss),var(--pine));display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.5);font-family:"DM Mono";font-size:.7rem;text-align:center;padding:10px}
  .guide h3{font-size:1.9rem;margin:6px 0 12px}
  .guide p{color:var(--ink-soft);max-width:640px;margin-bottom:10px}
  @media(max-width:680px){.guide .grid{grid-template-columns:1fr;text-align:center}.guide .photo{margin:0 auto}}

  .options{padding:64px 0;text-align:center}
  .options .eyebrow{display:block;margin-bottom:8px}
  .options h2{font-size:clamp(1.8rem,4vw,2.6rem);margin-bottom:34px}
  .opt-grid{display:grid;grid-template-columns:1fr 1fr;gap:22px}
  .opt{border:1px solid var(--line);border-radius:var(--r);overflow:hidden;background:#fff;text-align:left;transition:transform .2s,box-shadow .2s}
  .opt:hover{transform:translateY(-4px);box-shadow:0 18px 40px rgba(23,48,38,.10)}
  .opt .top{height:130px;background:linear-gradient(135deg,var(--river),var(--moss))}
  .opt:nth-child(2) .top{background:linear-gradient(135deg,var(--meadow),var(--moss))}
  .opt .body{padding:24px}
  .opt h4{font-size:1.35rem;margin-bottom:6px}
  .opt p{color:var(--ink-soft);font-size:.95rem;margin-bottom:18px}
  @media(max-width:680px){.opt-grid{grid-template-columns:1fr}}

  .flybuy{background:var(--meadow);color:var(--pine);padding:50px 0}
  .flybuy .wrap{display:grid;grid-template-columns:auto 1fr auto;gap:26px;align-items:center}
  .flybuy .ico{font-size:2.6rem;line-height:1}
  .flybuy h3{font-size:clamp(1.5rem,3.4vw,2.2rem);margin-bottom:6px}
  .flybuy p{font-size:1rem;max-width:640px;color:#23304a}
  .flybuy .terms{font-family:"DM Mono";font-size:.7rem;margin-top:8px;opacity:.78}
  @media(max-width:760px){.flybuy .wrap{grid-template-columns:1fr;text-align:center}.flybuy .btn{justify-self:center}}

  .pitch{background:var(--pine);color:var(--paper);padding:78px 0;overflow:hidden}
  .pitch .wrap{position:relative;z-index:2}
  .pitch .eyebrow{color:var(--meadow-soft)}
  .pitch h2{font-size:clamp(2rem,5vw,3.4rem);color:#fff;max-width:760px;margin:10px 0 8px}
  .pitch h2 em{font-style:italic;color:var(--meadow-soft)}
  .pitch .lead{font-size:1.05rem;color:rgba(255,255,255,.82);max-width:720px;margin-bottom:16px}

  .lots{padding:74px 0;background:var(--paper)}
  .lots .head{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:14px;margin-bottom:34px}
  .lots h2{font-size:clamp(1.9rem,4.5vw,3rem)}
  .lots .note{font-family:"DM Mono";font-size:.78rem;color:var(--ink-soft);max-width:300px}
  .lot-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
  .lot{position:relative;border:1px solid var(--line);border-radius:var(--r);overflow:hidden;background:#fff;transition:transform .2s,box-shadow .2s;display:flex;flex-direction:column}
  .lot:hover{transform:translateY(-5px);box-shadow:0 20px 44px rgba(23,48,38,.12)}
  .lot .img{aspect-ratio:4/3;background:linear-gradient(135deg,#13294d,#2e4a86);position:relative;display:flex;align-items:flex-end;background-size:cover;background-position:center}
  .lot .num{position:absolute;top:12px;right:14px;font-family:"DM Mono";font-weight:500;font-size:.78rem;color:var(--meadow-soft);background:rgba(0,0,0,.32);padding:3px 9px;border-radius:99px}
  .lot .statustag{position:absolute;top:12px;left:14px;font-family:"DM Mono";font-size:.64rem;font-weight:500;text-transform:uppercase;letter-spacing:.08em;padding:3px 9px;border-radius:99px;background:#fff;color:var(--pine)}
  .lot .statustag.available{background:#2e6b34;color:#fff}
  .lot .statustag.sold{background:#b42318;color:#fff}
  .lot .ph{font-family:"DM Mono";font-size:.66rem;color:rgba(255,255,255,.5);padding:12px}
  .lot .body{padding:18px 20px 22px;display:flex;flex-direction:column;flex:1}
  .lot h4{font-size:1.22rem;margin-bottom:4px}
  .lot .meta{font-family:"DM Mono";font-size:.8rem;color:var(--river)}
  .lot .desc{font-size:.88rem;color:var(--ink-soft);margin-top:9px;line-height:1.5;flex:1}
  .lot .price{font-family:"DM Mono";font-weight:500;font-size:1.35rem;color:var(--pine);margin-top:12px}
  .lot .viewlink{margin-top:12px;font-family:"DM Mono";font-size:.74rem;text-transform:uppercase;letter-spacing:.06em;color:var(--river);font-weight:500}
  .lot.sold{opacity:.6}
  @media(max-width:920px){.lot-grid{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:560px){.lot-grid{grid-template-columns:1fr}}

  .highlights{background:var(--paper-2);padding:70px 0}
  .highlights h2{font-size:clamp(1.8rem,4vw,2.6rem);margin-bottom:30px;text-align:center}
  .perks-h{text-align:center;font-family:"DM Mono";font-size:.76rem;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-soft);margin:6px 0 18px}
  .perks{max-width:920px;margin:0 auto;display:grid;grid-template-columns:repeat(2,1fr);gap:8px 36px}
  .perks .pk{display:flex;gap:10px;align-items:flex-start;padding:9px 0;border-bottom:1px dashed var(--line);font-size:.95rem}
  .perks .pk b{color:var(--gold-ink);flex:none}
  @media(max-width:640px){.perks{grid-template-columns:1fr}}

  .location{padding:78px 0;background:#fff}
  .location .eyebrow{display:block;margin-bottom:8px}
  .location h2{font-size:clamp(1.9rem,4.5vw,3rem);max-width:740px;margin-bottom:8px}
  .location h2 em{font-style:italic;color:var(--gold-ink)}
  .location p{color:var(--ink-soft);max-width:760px;margin-bottom:14px}
  .drives{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-top:34px}
  .drive{border:1px solid var(--line);border-radius:var(--r);padding:20px;background:var(--paper)}
  .drive .t{font-family:"DM Mono";font-size:1.6rem;font-weight:500;color:var(--river)}
  .drive .p{font-size:.9rem;color:var(--ink-soft);margin-top:4px}

  .areamap-sec{padding:74px 0;background:var(--paper)}
  .areamap-sec .eyebrow{display:block;margin-bottom:8px}
  .areamap-sec h2{font-size:clamp(1.8rem,4vw,2.6rem);margin-bottom:8px}
  .areamap-sec > .wrap > p{color:var(--ink-soft);max-width:640px;margin-bottom:22px}
  .area-grid{display:flex;gap:22px;align-items:stretch}
  .area-mapwrap{flex:1 1 60%;min-width:0}
  #areamap{width:100%;height:520px;border:1px solid var(--line);border-radius:var(--r);overflow:hidden;z-index:1}
  .area-listing{flex:0 0 36%;background:#fff;border:1px solid var(--line);border-radius:var(--r);overflow:hidden;display:flex;flex-direction:column}
  .al-photo{width:100%;height:210px;background-size:cover;background-position:center;flex:none}
  .al-photo-emoji{display:flex;align-items:center;justify-content:center;font-size:3.6rem}
  .al-body{padding:24px;display:flex;flex-direction:column}
  .al-drive{align-self:flex-start;font-family:"DM Mono",monospace;font-size:.72rem;color:var(--river);background:var(--paper-2);border:1px solid var(--line);padding:5px 11px;border-radius:999px;margin-bottom:14px}
  .area-listing .al-cat{display:inline-block;align-self:flex-start;font-size:.64rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:4px 11px;border-radius:999px;color:#fff;margin-bottom:12px}
  .area-listing h3{font-size:1.3rem;line-height:1.22;margin:0 0 10px;color:var(--ink)}
  .area-listing .al-body p{color:var(--ink-soft);font-size:.93rem;line-height:1.55;margin:0 0 18px}
  .al-btns{display:flex;flex-wrap:wrap;gap:9px}
  .al-btn{display:inline-flex;align-items:center;gap:6px;font-family:"DM Sans",sans-serif;font-weight:600;font-size:.82rem;padding:9px 15px;border-radius:999px;transition:transform .15s,background .15s,color .15s;cursor:pointer}
  .al-btn:hover{transform:translateY(-1px)}
  .al-web{background:var(--meadow);color:var(--pine)}
  .al-web:hover{background:var(--meadow-soft)}
  .al-dir{background:var(--pine);color:#fff}
  .al-dir:hover{background:var(--pine-2)}
  .al-sv{background:transparent;border:1.5px solid var(--moss);color:var(--moss)}
  .al-sv:hover{background:var(--moss);color:#fff}
  @media(max-width:820px){.al-photo{height:180px}}
  @media(max-width:820px){.area-grid{flex-direction:column}.area-listing{flex:auto}#areamap{height:400px}}
  .area-legend{display:flex;flex-wrap:wrap;gap:10px 18px;margin-top:18px;font-size:.82rem;color:var(--ink-soft)}
  .area-legend span{display:inline-flex;align-items:center;gap:7px}
  .area-legend i{width:13px;height:13px;border-radius:50%;display:inline-block;border:1px solid rgba(0,0,0,.18)}

  .lotmap{padding:74px 0;background:var(--paper-2)}
  .lotmap .eyebrow{display:block;margin-bottom:8px}
  .lotmap h2{font-size:clamp(1.8rem,4vw,2.6rem);margin-bottom:8px}
  .lotmap p{color:var(--ink-soft);max-width:620px;margin-bottom:24px}
  #lotmap{width:100%;aspect-ratio:16/8;border:1px solid var(--line);border-radius:var(--r);overflow:hidden;z-index:1}
  .map-ph{width:100%;aspect-ratio:16/8;border:1px solid var(--line);border-radius:var(--r);background:linear-gradient(135deg,#d8e1ef,#c6d3e7);display:flex;align-items:center;justify-content:center;font-family:"DM Mono";font-size:.8rem;color:var(--ink-soft);text-align:center;line-height:1.8}

  .purchase{background:var(--pine);color:var(--paper);padding:78px 0;overflow:hidden}
  .purchase .wrap{position:relative;z-index:2}
  .purchase h2{font-size:clamp(1.9rem,4.5vw,3rem);color:#fff;margin:8px 0 36px}
  .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:26px}
  .step .n{font-family:"DM Mono";font-size:.8rem;color:var(--meadow-soft);letter-spacing:.2em}
  .step h4{font-size:1.3rem;color:#fff;margin:8px 0 8px}
  .step p{color:rgba(255,255,255,.78);font-size:.95rem}
  .step{border-top:2px solid var(--meadow);padding-top:18px}
  @media(max-width:760px){.steps{grid-template-columns:1fr}}

  .financing{padding:70px 0;background:var(--paper)}
  .financing .grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
  .financing h2{font-size:clamp(1.8rem,4vw,2.6rem);margin-bottom:14px}
  .financing p{color:var(--ink-soft);margin-bottom:14px;max-width:520px}
  .fin-list{list-style:none}
  .fin-list li{font-family:"DM Mono";padding:13px 0;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;font-size:.92rem}
  .fin-list li b{color:var(--pine)}
  @media(max-width:760px){.financing .grid{grid-template-columns:1fr;gap:28px}}

  .developer{background:var(--paper-2);padding:78px 0}
  .developer .grid{display:grid;grid-template-columns:1.1fr 1fr;gap:48px;align-items:center}
  .developer .eyebrow{display:block;margin-bottom:8px}
  .developer h2{font-size:clamp(1.9rem,4vw,2.8rem);margin-bottom:6px}
  .developer .tag{font-family:"Fraunces";font-style:italic;color:var(--gold-ink);font-size:1.1rem;margin-bottom:16px}
  .developer p{color:var(--ink-soft);margin-bottom:14px}
  .dev-pkg{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:18px}
  .dev-pkg div{font-family:"DM Mono";font-size:.85rem;background:#fff;border:1px solid var(--line);border-radius:10px;padding:12px 14px}
  .dev-img{aspect-ratio:4/3;border-radius:var(--r);background:linear-gradient(135deg,var(--river),var(--pine));display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.45);font-family:"DM Mono";font-size:.72rem}
  blockquote.eker{text-align:center;margin:46px auto 0;max-width:640px;font-family:"Fraunces";font-style:italic;font-size:1.45rem;color:var(--pine)}
  blockquote.eker cite{display:block;font-family:"DM Mono";font-style:normal;font-size:.78rem;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-soft);margin-top:12px}
  @media(max-width:760px){.developer .grid{grid-template-columns:1fr;gap:28px}}

  .guidecta{background:#fff;padding:0 0 70px}
  .guidecta .box{max-width:var(--maxw);margin:0 auto;background:linear-gradient(135deg,var(--moss),var(--pine));border-radius:var(--r);padding:40px;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;color:#fff}
  .guidecta h3{color:#fff;font-size:1.6rem}
  .guidecta p{color:rgba(255,255,255,.82);max-width:520px;margin-top:6px}

  .gallery{padding:70px 0;background:#fff}
  .gallery h2{font-size:clamp(1.8rem,4vw,2.6rem);margin-bottom:8px;text-align:center}
  .gallery p{color:var(--ink-soft);max-width:620px;margin:0 auto 30px;text-align:center}
  .g-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
  .g-grid div{aspect-ratio:4/3;border-radius:10px;background:linear-gradient(135deg,#13294d,#2e4a86);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.4);font-family:"DM Mono";font-size:.62rem}
  @media(max-width:760px){.g-grid{grid-template-columns:repeat(2,1fr)}}

  .final{background:linear-gradient(180deg,#122a4d,#0a1628);color:var(--paper);padding:84px 0;text-align:center;overflow:hidden}
  .final .wrap{position:relative;z-index:2}
  .final h2{font-size:clamp(2rem,5vw,3.4rem);color:#fff;max-width:760px;margin:10px auto 14px}
  .final p{color:rgba(255,255,255,.82);max-width:560px;margin:0 auto 28px}
  .final .cta-row{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}

  footer{background:var(--ink);color:rgba(255,255,255,.6);padding:46px 0 30px;font-size:.82rem}
  footer .top{display:flex;justify-content:space-between;gap:24px;flex-wrap:wrap;border-bottom:1px solid rgba(255,255,255,.12);padding-bottom:24px;margin-bottom:22px}
  footer a:hover{color:#fff}
  footer .badges{display:flex;gap:16px;align-items:center}
  footer .badge{font-family:"DM Mono";font-size:.62rem;border:1px solid rgba(255,255,255,.25);border-radius:8px;padding:8px 10px;text-align:center;line-height:1.3}
  .disclosure{font-size:.72rem;color:rgba(255,255,255,.45);line-height:1.7;max-width:880px}
  .disclosure b{color:rgba(255,255,255,.7)}

  @media(max-width:760px){
    nav ul{display:none}
    .menu-toggle{display:inline-block}
    nav ul.open{display:flex;position:absolute;top:100%;left:0;right:0;flex-direction:column;background:var(--paper);padding:18px 22px;border-bottom:1px solid var(--line);gap:16px}
    .utility .left{display:none}
  }
  @media(prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important;scroll-behavior:auto!important}}
  .reveal{opacity:0;transform:translateY(22px);transition:opacity .7s ease,transform .7s ease}
  .reveal.in{opacity:1;transform:none}
</style>
</head>
<body data-sale-date={saleDate} data-prop-image={propImage}>

<div class="utility">
  <div class="wrap">
    <div class="left"><a href="mailto:David@alot.land">David@alot.land</a></div>
    <div class="right">
      <a href={`tel:+1${phoneRaw}`}><strong>{phoneDisp}</strong></a>
      <a href="#contact">Book a Showing</a>
    </div>
  </div>
</div>

<header class="nav">
  <div class="wrap">
    <a class="brand" href="#top"><span class="mark" aria-hidden="true"></span> Sugar&nbsp;Tree&nbsp;Vista</a>
    <nav>
      <button class="menu-toggle" aria-label="Menu" id="menuBtn">☰</button>
      <ul id="navlist">
        <li><a href="#lots">The Lots</a></li>
        <li><a href="#highlights">Highlights</a></li>
        <li><a href="#location">Location</a></li>
        <li><a href="#explore">Explore</a></li>
        <li><a href="#purchase">How to Buy</a></li>
        <li><a href="#financing">Financing</a></li>
        <li><a href={`tel:+1${phoneRaw}`} style="color:var(--meadow);font-weight:600">Call / Text</a></li>
      </ul>
    </nav>
  </div>
</header>

<div class="event-bar">
  <div class="wrap eb-wrap">
    <ul class="eb-points">
      <li>One-Day Land Sale</li>
      <li><span id="sale-date">&mdash;</span></li>
      <li>First Come, First Served</li>
      <li>Only 10 View Lots</li>
    </ul>
    <span class="countdown" id="countdown">
      <span><b id="cd-d">--</b><small>Days</small></span>
      <span><b id="cd-h">--</b><small>Hrs</small></span>
      <span><b id="cd-m">--</b><small>Min</small></span>
      <span><b id="cd-s">--</b><small>Sec</small></span>
    </span>
  </div>
</div>

<section class="hero" id="top" style={heroImage ? `background-image:linear-gradient(180deg,rgba(10,22,40,.80),rgba(18,42,77,.74)),url('${heroImage}');background-size:cover;background-position:center` : ''}>
  <div class="topo" aria-hidden="true"><svg viewBox="0 0 1200 600" preserveAspectRatio="xMidYMid slice"><path d="M-20,120 C200,60 380,180 620,120 S1000,40 1240,140"/><path d="M-20,200 C220,140 420,260 640,200 S1010,120 1240,220"/><path d="M-20,290 C240,230 440,350 660,290 S1020,210 1240,310"/><path d="M-20,390 C260,330 460,450 680,390 S1040,310 1240,410"/></svg></div>
  <div class="wrap">
    <span class="eyebrow">Decatur County, Tennessee &nbsp;·&nbsp; 10 View Lots</span>
    <h1>Sugar&nbsp;Tree&nbsp;<em>Vista</em></h1>
    <p class="sub">Ten ridgeline meadow-view tracts above the Tennessee River at Kentucky Lake. Wide road frontage, deep privacy, and views that go on for miles.</p>
    <div class="stats">
      <div class="stat"><div class="n">5&ndash;11</div><div class="l">Acre Tracts</div></div>
      <div class="stat"><div class="n">$59K</div><div class="l">Starting Price</div></div>
      <div class="stat"><div class="n">10</div><div class="l">Total Lots</div></div>
      <div class="stat"><div class="n">8&nbsp;min</div><div class="l">To the Marina</div></div>
    </div>
    <div class="cta-row">
      <a class="btn btn-primary" href="#contact">Book a Private Showing</a>
      <a class="btn btn-ghost" href={`tel:+1${phoneRaw}`}>Call or Text {phoneDisp}</a>
    </div>
    <div class="promo-pill">✈&nbsp; <span><b>$1,500 Fly &amp; Buy Credit</b> &mdash; we cover your flight and hotel, up to $1,500 off the price of the lot you buy.</span></div>

    <div class="video-frame">
      {heroVideoUrl ? (
        <iframe src={heroVideoUrl} title="Sugar Tree Vista walkthrough" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>
      ) : (
        <><div class="play">▶</div><div class="ph">TODO — add the walkthrough video in /admin → Sugar Tree Vista → Hero Video URL</div></>
      )}
    </div>
  </div>
</section>

<section class="options" id="contact">
  <div class="wrap">
    <span class="eyebrow">The Next Step</span>
    <h2>Two Easy Ways to Start</h2>
    <div class="opt-grid">
      <div class="opt">
        <div class="top"></div>
        <div class="body">
          <h4>Book a Private Showing</h4>
          <p>Showings are held on our one-day sale Saturdays. Lots go first come, first served &mdash; the earliest slots get the best pick.</p>
          <!-- TODO: GHL "Sugar Tree Vista — Showing" calendar URL -->
          <a class="btn btn-primary" href="#" data-ghl="showing">Check Available Showing Times</a>
        </div>
      </div>
      <div class="opt">
        <div class="top"></div>
        <div class="body">
          <h4>Book a 20-Minute Land Call</h4>
          <p>Prefer to talk first? Get pricing, lot details, maps, and financing options &mdash; including the $1,500 Fly &amp; Buy Credit &mdash; over the phone or a quick Zoom.</p>
          <!-- TODO: GHL "Sugar Tree Vista — Land Consult" calendar URL -->
          <a class="btn btn-dark" href="#" data-ghl="consult">Schedule a Land Consult</a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="flybuy">
  <div class="wrap">
    <div class="ico">✈</div>
    <div>
      <h3>$1,500 Fly &amp; Buy Credit</h3>
      <p>Coming from out of state? Fly in to walk the land, and when you buy a lot we'll credit up to <b>$1,500</b> of your travel &mdash; flights and hotel &mdash; toward the purchase price.</p>
      <p class="terms">Credit applies only with the purchase of a lot and is applied to the lot price. Not redeemable for cash. One credit per transaction. Proof of travel required.</p>
    </div>
    <a class="btn btn-dark" href="#contact">Book a Showing &amp; Claim It</a>
  </div>
</section>

<section class="pitch">
  <div class="topo" aria-hidden="true"><svg viewBox="0 0 1200 500" preserveAspectRatio="xMidYMid slice"><path d="M-20,90 C240,30 440,150 700,90 S1080,10 1240,110"/><path d="M-20,190 C260,130 460,250 720,190 S1100,110 1240,210"/><path d="M-20,300 C280,240 480,360 740,300 S1120,220 1240,320"/></svg></div>
  <div class="wrap">
    <span class="eyebrow">Ridgeline Living, Done Right</span>
    <h2>Your land, <em>your way</em> &mdash; on the high ground above the lake.</h2>
    <p class="lead">Every tract at Sugar Tree Vista sits on a meadow ridgeline with long views over the Tennessee hills. The lots are a mix of open meadow and mature woods, with wide road frontage on each one so your nearest neighbor is never on top of you. Build a cabin, set up an RV, run trails, or just hold a beautiful piece of Tennessee.</p>
    <p class="lead">And these aren't raw squares on a map. Graded driveways are already in, and every lot comes with a soil map marking approved septic locations &mdash; so you can take it straight to the county and pull a permit. Unrestricted. No crowds. Just space, privacy, and a view you won't get tired of.</p>
    <a class="btn btn-primary" href="#lots" style="margin-top:10px">See the Available Lots</a>
  </div>
</section>

<section class="lots" id="lots">
  <div class="wrap">
    <div class="head">
      <div>
        <span class="eyebrow">Only Ten Tracts to Choose From</span>
        <h2>Pick Your View</h2>
      </div>
      <p class="note">Live names, acreage, pricing &amp; status pull from the listings backend. Click a lot for full details.</p>
    </div>
    <div class="lot-grid">
      {lots.map(lot => (
        <a class={`lot ${lot.status === 'sold' ? 'sold' : ''}`} href={`/listings/${lot.slug}`} target="_blank" rel="noopener">
          <div class="img" style={lot.photo ? `background-image:url('${lot.photo}')` : ''}>
            <span class="num">{`LOT ${String(lot.num).padStart(2, '0')}`}</span>
            {lot.status !== 'available' && <span class={`statustag ${lot.status}`}>{statusPill[lot.status]}</span>}
            {!lot.photo && <span class="ph">Photo coming soon</span>}
          </div>
          <div class="body">
            <h4>{lot.name}</h4>
            <div class="meta">{lot.acreage} ACRES</div>
            <p class="desc">{lot.desc}</p>
            <div class="price">{lot.price}</div>
            <div class="viewlink">View lot details →</div>
          </div>
        </a>
      ))}
    </div>
    <p class="note" style="margin-top:24px;text-align:center;max-width:none">Lots are reserved on a first-come, first-served basis by private showing. <b>Prices and acreage subject to change without notice.</b></p>
  </div>
</section>

<section class="highlights" id="highlights">
  <div class="wrap">
    <span class="eyebrow" style="display:block;text-align:center;margin-bottom:8px">Why Sugar Tree Vista</span>
    <h2>Every Purchase Includes</h2>
    <div class="perks">
      <div class="pk"><b>✓</b><span>Power being run to the road on every lot (coming soon)</span></div>
      <div class="pk"><b>✓</b><span>Drill your own well &mdash; well drillers on our <a href="/resources/preferred-vendors" style="color:var(--river);text-decoration:underline">preferred-vendor list</a></span></div>
      <div class="pk"><b>✓</b><span>Soil map included &mdash; approved septic locations marked</span></div>
      <div class="pk"><b>✓</b><span>Graded driveway already installed (with culverts where needed)</span></div>
      <div class="pk"><b>✓</b><span>Fully buildable &mdash; unrestricted, no HOA</span></div>
      <div class="pk"><b>✓</b><span>New survey on every lot</span></div>
      <div class="pk"><b>✓</b><span>Warranty Deed &amp; clear title</span></div>
      <div class="pk"><b>✓</b><span>10% discount for cash purchases</span></div>
      <div class="pk"><b>✓</b><span>Owner financing available &mdash; ask about terms</span></div>
      <div class="pk"><b>✓</b><span>$1,500 Fly &amp; Buy travel credit (with purchase)</span></div>
      <div class="pk"><b>✓</b><span>No time limit to build</span></div>
      <div class="pk"><b>✓</b><span>Perfect for cabins, homes, RVs &amp; travel trailers</span></div>
    </div>
  </div>
</section>

<section class="location" id="location">
  <div class="wrap">
    <span class="eyebrow">The Location</span>
    <h2>Tennessee's <em>big backyard</em> &mdash; in the path of growth.</h2>
    <p>Sugar Tree Vista sits in the highlands of Decatur County &mdash; off Ray Miller Rd &amp; Low Gap Rd, Sugar Tree, TN 38380 &mdash; on the ridgelines above the Tennessee River where it widens into Kentucky Lake, one of the largest lakes east of the Mississippi. This is small-town Tennessee at its best: quiet roads, real neighbors, and natural beauty in every direction.</p>
    <!-- TODO: drive times are PLACEHOLDERS pending David's verified numbers -->
    <div class="drives">
      {drives.map(d => (<div class="drive"><div class="t">{d.t}</div><div class="p">{d.p}</div></div>))}
    </div>
  </div>
</section>

<section class="areamap-sec" id="explore">
  <div class="wrap">
    <span class="eyebrow">Explore the Area</span>
    <h2>Everything to Do, <em>All Around You</em></h2>
    <p>Click a pin for the full listing, one-click directions, and Street View. From the closest boat launch to Kentucky Lake day-trips, here's what's waiting just outside your gate.</p>
    <div class="area-grid">
      <div class="area-mapwrap"><div id="areamap"></div></div>
      <aside class="area-listing" id="area-listing"></aside>
    </div>
    <div class="area-legend">
      <span><i style="background:#f5b800"></i> The property</span>
      <span><i style="background:#3b55a3"></i> Water &amp; marinas</span>
      <span><i style="background:#2e6b34"></i> State parks</span>
      <span><i style="background:#8f6e00"></i> Golf</span>
      <span><i style="background:#0a1628"></i> Town</span>
      <span><i style="background:#c47f17"></i> Kentucky Lake day-trips</span>
    </div>
    <p style="font-size:.72rem;margin-top:10px">Drive times are estimates pending verification.</p>
  </div>
</section>

<section class="lotmap" id="map">
  <div class="wrap">
    <span class="eyebrow">The Lay of the Land</span>
    <h2>See Every Lot on the Map</h2>
    <p>Each pin is a homesite &mdash; click one for acreage, price, and current availability.</p>
    {lotPins.length > 0
      ? <div id="lotmap"></div>
      : <div class="map-ph">Lot map coming soon<br><small>add each lot's GPS in the CMS and pins appear here automatically</small></div>}
  </div>
</section>

<section class="purchase" id="purchase">
  <div class="topo" aria-hidden="true"><svg viewBox="0 0 1200 400" preserveAspectRatio="xMidYMid slice"><path d="M-20,80 C240,30 460,130 720,80 S1100,20 1240,100"/><path d="M-20,180 C260,130 480,230 740,180 S1120,120 1240,200"/></svg></div>
  <div class="wrap">
    <span class="eyebrow">Learn More About</span>
    <h2>How to Purchase</h2>
    <div class="steps">
      <div class="step"><div class="n">STEP 01</div><h4>Book your showing</h4><p>Call, text, or use the scheduler to lock in a private appointment. The earliest showings see the most lots available.</p></div>
      <div class="step"><div class="n">STEP 02</div><h4>Walk the land with me</h4><p>We'll tour the tracts together. You'll see the views, the road frontage, and the boundaries &mdash; everything you need to decide with confidence.</p></div>
      <div class="step"><div class="n">STEP 03</div><h4>Reserve &amp; close</h4><p>Found your lot? Reserve it on the spot. We handle the survey, title, and paperwork, and walk you through cash or owner-financing to closing.</p></div>
    </div>
    <a class="btn btn-primary" href="#contact" style="margin-top:34px">Start With a Showing</a>
  </div>
</section>

<section class="financing" id="financing">
  <div class="wrap">
    <div class="grid">
      <div>
        <span class="eyebrow">Offering Excellent</span>
        <h2>Financing</h2>
        <p>Cash buyers get 10% off the price. Owner financing is available on select terms &mdash; handled directly with David, case by case &mdash; and a land loan or your own lender works too.</p>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <a class="btn btn-primary" href="/land-payment-calculator?community=sugar-tree-vista">Estimate My Seller-Finance Payment</a>
          <a class="btn btn-dark" href={`tel:+1${phoneRaw}`}>Call to Talk Financing</a>
        </div>
      </div>
      <ul class="fin-list">
        <li><span>Owner Financing</span><b>Ask About Terms</b></li>
        <li><span>Cash Purchase</span><b>10% Cash Discount</b></li>
        <li><span>Land Loans</span><b>Supported</b></li>
        <li><span>Down Payment</span><b>By Agreement</b></li>
      </ul>
    </div>
  </div>
</section>

<section class="developer" id="developer">
  <div class="wrap">
    <div class="grid">
      <div>
        <span class="eyebrow">The Developer</span>
        <h2>Alot Of Land LLC</h2>
        <div class="tag">Fewer, better tracts &mdash; chosen for beauty first.</div>
        <p>Alot Of Land LLC, founded by David A. Stone, finds and improves standout acreage across Middle Tennessee. We're selective on purpose &mdash; we'd rather develop one extraordinary property the right way than push volume.</p>
        <p>When you buy at Sugar Tree Vista, the hard parts are already handled: a fresh survey, clear title, and a clean, honest closing.</p>
        <div class="dev-pkg"><div>✓ New Survey</div><div>✓ Clear Title</div><div>✓ Warranty Deed</div><div>✓ Owner Financing</div></div>
      </div>
      <div class="dev-img" style={developerPhoto ? `background-image:url('${developerPhoto}');background-size:cover;background-position:center` : ''}>{!developerPhoto && 'Developer photo'}</div>
    </div>
    <blockquote class="eker">&ldquo;Don't wait to buy land. Buy land and wait.&rdquo;<cite>— A land investor's favorite rule</cite></blockquote>
  </div>
</section>

<section class="guidecta">
  <div class="box">
    <div>
      <h3>Get the Sugar Tree Vista Area Guide</h3>
      <p>Drive times, things to do, the lake, and what makes this corner of Tennessee special &mdash; in one PDF.</p>
    </div>
    <!-- TODO: gate behind a GHL email-capture form (fires AreaGuideDownload + Lead). Direct link for now. -->
    <a class="btn btn-primary" href="/guides/sugar-tree-vista-area-guide.pdf" target="_blank" rel="noopener" id="guideDownload">Download the Area Guide</a>
  </div>
</section>

<section class="gallery" id="gallery">
  <div class="wrap">
    <h2>Property Photos</h2>
    <p>Beauty comes first for us. See the ridgelines, the meadows, the road frontage, and the lake country just minutes away.</p>
    <div class="g-grid">
      {gallery.length > 0
        ? gallery.map(src => (<div style={`background-image:url('${src}');background-size:cover;background-position:center`}></div>))
        : Array.from({ length: 8 }).map(() => (<div>Photo coming soon</div>))}
    </div>
  </div>
</section>

<section class="final">
  <div class="topo" aria-hidden="true"><svg viewBox="0 0 1200 400" preserveAspectRatio="xMidYMid slice"><path d="M-20,90 C240,30 460,150 720,90 S1100,20 1240,110"/><path d="M-20,200 C260,150 480,250 740,200 S1120,140 1240,220"/></svg></div>
  <div class="wrap">
    <span class="eyebrow">Limited Showings</span>
    <h2>Come see it before someone else does.</h2>
    <p>Only ten lots, reserved first come, first served by private showing. The earliest appointments get the pick of the views.</p>
    <div class="cta-row">
      <a class="btn btn-primary" href={`tel:+1${phoneRaw}`}>Call or Text {phoneDisp}</a>
      <a class="btn btn-ghost" href="#contact">Book a Showing Online</a>
    </div>
  </div>
</section>

<section class="guide">
  <div class="wrap">
    <span class="eyebrow">Your Land Guide</span>
    <div class="grid">
      <div class="photo" style={guidePhoto ? `background-image:url('${guidePhoto}');background-size:cover;background-position:center` : ''}>{!guidePhoto && (<>Land&nbsp;Guide<br>Photo</>)}</div>
      <div>
        <h3>David A. Stone</h3>
        <p>I've spent my whole career around land &mdash; in the land and homebuilding business since my teens, building and selling for the better part of two decades, and now finding and improving the kind of acreage I'd want to own myself. Sugar Tree Vista is exactly that: high, private ground with views I couldn't walk away from.</p>
        <p>Whether you're looking for a weekend retreat, a place to build, a homestead, or a smart piece of land to hold, I'll walk every lot with you and tell you straight what each one is best for. No pressure &mdash; just an honest look at the property and your options.</p>
        <p><strong>Why I do this:</strong> I do it for my family &mdash; my two young sons. I want them to look up to me as a businessman and an entrepreneur, someone who does real things with his life. And I want to provide for my family while helping other families provide for theirs, through owning land.</p>
        <a class="btn btn-dark" href={`tel:+1${phoneRaw}`} style="margin-top:8px">Call or Text Me &mdash; {phoneDisp}</a>
      </div>
    </div>
  </div>
</section>

