<!-- Lot pins for the community map (only lots with GPS) -->
<script type="application/json" id="lot-pins" set:html={JSON.stringify(lotPins)}></script>
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script is:inline>
  // ---- year ----
  document.getElementById('yr').textContent = new Date().getFullYear();

  // ---- mobile menu ----
  document.getElementById('menuBtn').addEventListener('click', function(){ document.getElementById('navlist').classList.toggle('open'); });

  // ---- countdown (reads CMS sale date) ----
  var SALE = new Date(document.body.dataset.saleDate);
  document.getElementById('sale-date').textContent = SALE.toLocaleDateString('en-US',{weekday:'long', month:'long', day:'numeric'});
  function tick(){
    var d = Math.max(0, SALE.getTime() - Date.now());
    var day=Math.floor(d/86400000); d-=day*86400000;
    var hr=Math.floor(d/3600000); d-=hr*3600000;
    var min=Math.floor(d/60000); d-=min*60000;
    var sec=Math.floor(d/1000);
    var p=function(n){return String(n).padStart(2,'0');};
    document.getElementById('cd-d').textContent=p(day);
    document.getElementById('cd-h').textContent=p(hr);
    document.getElementById('cd-m').textContent=p(min);
    document.getElementById('cd-s').textContent=p(sec);
  }
  tick(); setInterval(tick,1000);

  // ---- scroll reveal ----
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
  },{threshold:.12});
  document.querySelectorAll('.lot, .opt, .drive, .pk, .step, .dev-pkg div, .g-grid div').forEach(function(el,i){
    el.classList.add('reveal'); el.style.transitionDelay=(Math.min(i,6)*40)+'ms'; io.observe(el);
  });

  // ===== Things-to-do map (free Leaflet/OSM + Google deep-links) =====
  (function(){
    var host=document.getElementById('areamap'), panel=document.getElementById('area-listing');
    if(!host||!panel||typeof L==='undefined') return;
    var COL={water:'#3b55a3',park:'#2e6b34',golf:'#8f6e00',town:'#0a1628',day:'#c47f17',prop:'#f5b800'};
    var CATL={water:'Water & marinas',park:'State park',golf:'Golf',town:'Town',day:'Kentucky Lake day-trip',prop:'The property'};
    var PROP={n:'Sugar Tree Vista',c:'prop',lat:35.8067,lng:-88.0273,img:(document.body.dataset.propImage||''),d:'The property — ten ridgeline view lots off Ray Miller Rd & Low Gap Rd, 5.4 to 11.4 acres, unrestricted, from $59,000.'};
    // n=name c=category lat/lng mins=est. drive (PLACEHOLDER, David verifying) w=website img=photo (TODO: confirm rights / self-host)
    var PTS=[
      {n:'The Ponderosa',c:'water',mins:10,lat:35.7841,lng:-87.9910,w:'https://decaturcountytn.gov/attractions/',img:'',d:"A private-club boat launch on the Tennessee River near Sugar Tree — your closest water access for fishing, boating, and sunset cruising on Kentucky Lake."},
      {n:'Cherokee Marina & Grill',c:'water',mins:20,lat:35.7310,lng:-88.0314,w:'https://www.facebook.com/cherokeeboatdock/',img:'https://cdn.elebase.io/f73a5e12-7a94-4da0-96b6-40fd97435fd2/0b6abaa1-0287-4f5c-ac18-a623b03be939-ten2ca79618f066341e5.jpg?q=90',d:"Full-service Tennessee River marina just east of Parsons with a floating grill, easy-access boat ramp, gas dock, and riverside RV spots."},
      {n:'Beech Bend Campground',c:'water',mins:30,lat:35.6117,lng:-88.0399,w:'https://decaturcountytennessee.org/beech-bend-campground/',img:'https://cdn.elebase.io/f73a5e12-7a94-4da0-96b6-40fd97435fd2/8405eacc-f94b-40cf-8004-014da9fc72a9-ten7aae7f8bb5f4f0993.jpg?q=90',d:"A quiet 11-acre Tennessee River campground five miles east of Parsons with 76 sites, two boat ramps, a playground, and bank fishing."},
      {n:'Mousetail Landing State Park',c:'park',mins:35,lat:35.6686,lng:-88.0078,w:'https://tnstateparks.com/parks/mousetail-landing',img:'',d:"An 1,867-acre park on the Tennessee River with 11 miles of hiking trails, a swimming beach, boat landing, and lakeside campsites."},
      {n:'Natchez Trace State Park',c:'park',mins:25,lat:35.8011,lng:-88.2730,w:'https://tnstateparks.com/parks/natchez-trace',img:'',d:"A sprawling 48,000-acre wilderness with three lakes for fishing, boating, and swimming, plus miles of trails for hiking, biking, and horseback riding."},
      {n:'Nathan Bedford Forrest State Park',c:'park',mins:50,lat:36.0833,lng:-87.9855,w:'https://tnstateparks.com/parks/nathan-bedford-forrest',img:'https://upload.wikimedia.org/wikipedia/commons/thumb/6/6d/Nathan-bedford-forrest-state-park-tn1.jpg/1280px-Nathan-bedford-forrest-state-park-tn1.jpg',d:"Perched above Kentucky Lake at Pilot Knob, with 20+ miles of trails, lakeside cabins, boat ramps, and the Tennessee River Folklife Center."},
      {n:'Tennessee River Golf Club',c:'golf',mins:40,lat:35.5636,lng:-88.0188,w:'https://www.tennesseerivergolfclub.com/',img:'https://lirp-cdn.multiscreensite.com/6dfda5be/dms3rep/multi/opt/G45+%281+of+1%29-b7a197bf-1920w.jpg',d:"A public 18-hole, par-71 course in the rolling hills beside the Tennessee River in Decaturville, with water in play on ten holes."},
      {n:'Parsons, TN',c:'town',mins:22,lat:35.6498,lng:-88.1267,w:'https://decaturcountytn.gov/city-of-parsons/',img:'',d:"The friendly seat of Decatur County on the Tennessee River — small-town shops, river access, groceries, pharmacy, and county events."},
      {n:'TN River Freshwater Pearl Farm',c:'day',mins:32,lat:35.9607,lng:-88.0373,w:'https://museum.tennesseeriverpearls.com/',img:'https://museum.tennesseeriverpearls.com/wp-content/uploads/2020/03/implanting.jpg',d:"North America's only freshwater pearl-culturing farm, near Camden — guided tours, a museum, and a showroom of Tennessee's state gem."},
      {n:'Birdsong Resort & Marina',c:'day',mins:32,lat:35.9678,lng:-88.0462,w:'https://resort.birdsong.com/',img:'https://resort.birdsong.com/wp-content/uploads/2020/02/sunset-2019.png',d:"A 58-acre Kentucky Lake resort near Camden with a 150-slip marina, cabins, lakeside RV and tent camping, a pool, and the pearl farm."},
      {n:'Patsy Cline Memorial',c:'day',mins:38,lat:36.0606,lng:-88.1612,w:'https://tennesseerivervalleygeotourism.org/entries/patsy-cline-memorial/341de19a-a0b1-4ed6-93eb-9c7ff1eb1406',img:'https://cdn.elebase.io/f73a5e12-7a94-4da0-96b6-40fd97435fd2/9ccedf52-d9c6-454d-8104-dca5affc8ae2-ten0d840b98526f3ad88.jpg?q=90',d:"A quiet wooded memorial off US-70 near Camden marking the 1963 plane crash that took country legend Patsy Cline."}
    ];
    var map=L.map(host,{scrollWheelZoom:false}).setView([PROP.lat,PROP.lng],11);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap',maxZoom:18}).addTo(map);
    map.on('focus',function(){ map.scrollWheelZoom.enable(); });
    map.on('blur',function(){ map.scrollWheelZoom.disable(); });
    function dir(p){ return 'https://www.google.com/maps/dir/?api=1&destination='+p.lat+','+p.lng; }
    function sv(p){ return 'https://www.google.com/maps/@?api=1&map_action=pano&viewpoint='+p.lat+','+p.lng; }
    function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;'); }
    var EMOJI={water:'🌊',park:'🌲',golf:'⛳',town:'🏙️',day:'⛴️',prop:'📍'};
    function render(p){
      var col=COL[p.c];
      var photo = p.img
        ? '<div class="al-photo" style="background-image:url(\''+p.img+'\')"></div>'
        : '<div class="al-photo al-photo-emoji" style="background:linear-gradient(135deg,'+col+',#0a1628)">'+(EMOJI[p.c]||'📍')+'</div>';
      var pill = '<span class="al-cat" style="background:'+col+(p.c==='prop'?';color:#0a1628':'')+'">'+CATL[p.c]+'</span>';
      var drive = p.mins ? '<span class="al-drive">📍 ~'+p.mins+' min from Sugar Tree Vista</span>' : '';
      var web = p.w ? '<a class="al-btn al-web" href="'+p.w+'" target="_blank" rel="noopener">Visit website ↗</a>' : '';
      panel.innerHTML = photo +
        '<div class="al-body">'+pill+
        '<h3>'+esc(p.n)+'</h3>'+drive+'<p>'+p.d+'</p>'+
        '<div class="al-btns">'+web+
        '<a class="al-btn al-dir" href="'+dir(p)+'" target="_blank" rel="noopener">Directions ↗</a>'+
        '<a class="al-btn al-sv" href="'+sv(p)+'" target="_blank" rel="noopener">Street View ↗</a></div></div>';
    }
    function addPin(p,big){
      var m=L.circleMarker([p.lat,p.lng],{radius:big?11:8,color:'#fff',weight:2,fillColor:COL[p.c],fillOpacity:1}).addTo(map);
      m.bindTooltip(p.n,{direction:'top'});
      m.on('click',function(){ render(p); map.panTo([p.lat,p.lng]); });
      return m;
    }
    PTS.forEach(function(p){ addPin(p,false); });
    addPin(PROP,true).openTooltip();
    render(PROP);
  })();

  // ===== Community lot map (only renders if lots have GPS) =====
  (function(){
    var host=document.getElementById('lotmap'); if(!host||typeof L==='undefined') return;
    var raw=document.getElementById('lot-pins'); var pins=[]; try{ pins=JSON.parse(raw.textContent||'[]'); }catch(e){}
    if(!pins.length) return;
    var SC={available:'#2e6b34','coming-soon':'#3b55a3','under-contract':'#f5b800',sold:'#b42318'};
    var map=L.map(host,{scrollWheelZoom:false});
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{attribution:'© OpenStreetMap',maxZoom:18}).addTo(map);
    var grp=[];
    pins.forEach(function(p){
      var m=L.circleMarker([p.lat,p.lng],{radius:10,color:'#fff',weight:2,fillColor:SC[p.status]||'#3b55a3',fillOpacity:1}).addTo(map);
      m.bindPopup('<b>'+p.name+'</b><br>'+p.acreage+' acres · '+(p.price||'')+'<br><a href="/listings/'+p.slug+'" target="_blank" rel="noopener">View details →</a>');
      grp.push([p.lat,p.lng]);
    });
    map.fitBounds(grp,{padding:[40,40],maxZoom:15});
  })();
</script>
</body>
</html>
