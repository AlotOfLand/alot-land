---
import BaseLayout from '../layouts/BaseLayout.astro';
import MailerLiteForm from '../components/MailerLiteForm.astro';
import { getCollection } from 'astro:content';

const allEbooks = await getCollection('ebooks').catch(() => []);
const buyersEbook = allEbooks.find(e => e.data.audience === 'buyers' && e.data.featured);
---

<BaseLayout
  title="Find Land For Me"
  description="Tell us what land you're looking for and we'll source it off-market. Arizona and Tennessee."
  noChat={true}
>
  <!-- Hero -->
  <div class="bg-bg-dark text-white py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display font-black text-4xl sm:text-5xl mb-4">
        Tell Us What You Want — We'll Go Find It
      </h1>
      <p class="text-gray-300 text-lg leading-relaxed">
        We specialize in sourcing off-market land deals. Tell us your target area, budget, and what you're looking for — we'll do the legwork.
      </p>
    </div>
  </div>

  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
      <iframe
        src="https://brand.alot.land/widget/form/lEAT5zz8MjGelI76TMfj"
        style="width:100%;border:none;border-radius:8px"
        id="inline-lEAT5zz8MjGelI76TMfj"
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name="Find Land"
        data-height="2500"
        data-layout-iframe-id="inline-lEAT5zz8MjGelI76TMfj"
        data-form-id="lEAT5zz8MjGelI76TMfj"
        title="Find Land"
      ></iframe>
      <script src="https://brand.alot.land/js/form_embed.js"></script>
    </div>
  </div>

  <!-- Free Buyers Ebook -->
  {buyersEbook && (
    <div class="bg-bg-dark py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-3xl overflow-hidden shadow-xl">
          <div class="flex flex-col justify-center p-8">
            <span class="self-start text-xs font-bold px-2.5 py-1 rounded-full mb-3 bg-green-100 text-green-700">
              Land Buyers
            </span>
            <h2 class="font-display font-black text-2xl text-bg-dark mb-2">{buyersEbook.data.title}</h2>
            {buyersEbook.data.description && (
              <p class="text-gray-500 text-sm leading-relaxed mb-6">{buyersEbook.data.description}</p>
            )}
            <MailerLiteForm
              containerId="mlb2-40806955"
              formAction="https://assets.mailerlite.com/jsonp/2316201/forms/186551539589972998/subscribe"
              title="FREE Land Buyers E-Book"
              description="Get your free Land Owners Opportunity Guide — off-market deal tips, what to look for, what to avoid."
              successMessage="Check your email for your free <em>Land Owners Opportunity Guide</em>!"
            />
          </div>
        </div>
      </div>
    </div>
  )}

</BaseLayout>

