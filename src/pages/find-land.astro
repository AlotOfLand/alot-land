---
import BaseLayout from '../layouts/BaseLayout.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
---

<BaseLayout
  title="Find Land For Me"
  description="Tell us what land you're looking for and we'll source it off-market. Arizona and Tennessee."
  noChat={true}
>
  <!-- Hero -->
  <div class="bg-bg-dark text-white py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display font-black text-4xl sm:text-5xl mb-4">
        Tell Us What You Want — We'll Go Find It
      </h1>
      <p class="text-gray-300 text-lg leading-relaxed">
        We specialize in finding great land at great prices. Tell us your target area, budget, and what you're looking for — we'll do the legwork.
      </p>
    </div>
  </div>

  <!-- How it works / reassurance -->
  <div class="bg-bg-light border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid sm:grid-cols-3 gap-8 text-center">
        {[
          { icon: '📝', title: 'Tell Us What You Want', desc: 'Your target area, budget, acreage, and how you plan to use the land.' },
          { icon: '📬', title: 'We Source It Off-Market', desc: 'We reach out to landowners directly to find parcels that match — before they hit the market.' },
          { icon: '✅', title: 'Free & No Obligation', desc: "There's no cost to use this. If we find the right deal, we bring it to you." },
        ].map(item => (
          <div>
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-display font-bold text-bg-dark mb-2">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Testimonial -->
  <TestimonialSection variant="light" max={1} />

  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
      <iframe
        src="https://brand.alot.land/widget/form/lEAT5zz8MjGelI76TMfj"
        style="width:100%;height:1660px;border:none;border-radius:8px"
        id="inline-lEAT5zz8MjGelI76TMfj"
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name="Find Land"
        data-height="2500"
        data-layout-iframe-id="inline-lEAT5zz8MjGelI76TMfj"
        data-form-id="lEAT5zz8MjGelI76TMfj"
        title="Find Land"
      ></iframe>
      <script src="https://brand.alot.land/js/form_embed.js"></script>
    </div>
  </div>


</BaseLayout>

