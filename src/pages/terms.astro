  description="Terms of Service for Alot of Land LLC. Read our terms governing the use of alot.land and our services."
  noChat={true}
>
  <div class="bg-bg-dark text-white py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-display font-black text-4xl sm:text-5xl mb-3">Terms of Service</h1>
