---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { siteConfig } from '../config/site.js';

const allMembers = await getCollection('team');
const members = allMembers
  .filter(m => m.data.active)
  .sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  members.map(async m => ({ ...m, rendered: await render(m) }))
);

const siteOrigin = `https://${siteConfig.domain}`;
const teamSchema = members.length > 0 ? {
  '@context': 'https://schema.org',
  '@graph': members.map(m => ({
    '@type': 'Person',
    name: m.data.name,
    jobTitle: m.data.role,
    worksFor: { '@type': 'Organization', name: siteConfig.name, url: siteOrigin },
    ...(m.data.photo ? { image: m.data.photo.startsWith('http') ? m.data.photo : `${siteOrigin}${m.data.photo}` } : {}),
  })),
} : null;
---

<BaseLayout
  title="Our Team"
  description="Meet the team behind Alot of Land LLC — buying and selling land across Arizona and Tennessee."
>
  {teamSchema && <script slot="head" type="application/ld+json" set:html={JSON.stringify(teamSchema)} />}
  <!-- Hero -->
  <div class="bg-bg-dark text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display font-black text-4xl sm:text-5xl mb-4">Meet the Team</h1>
      <p class="text-gray-400 text-lg max-w-xl mx-auto">The people behind every deal — from the first mailer to the closing table.</p>
    </div>
  </div>

  <!-- Team Grid -->
  <section class="py-20 bg-bg-light">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      {rendered.length > 0 ? (
        <div class="grid sm:grid-cols-2 gap-10 max-w-3xl mx-auto">
          {rendered.map(member => (
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
              <!-- Photo (always-present initial avatar; photo covers it and hides itself on error) -->
              <div class="relative bg-gradient-to-br from-bg-dark to-gray-700 h-64 flex items-center justify-center">
                <div class="w-24 h-24 rounded-full bg-gold flex items-center justify-center font-display font-black text-bg-dark text-4xl">
                  {member.data.name.charAt(0)}
                </div>
                {member.data.photo && (
                  <img
                    src={member.data.photo}
                    alt={member.data.name}
                    class="absolute inset-0 w-full h-full object-cover object-top"
                    onerror="this.style.display='none'"
                  />
                )}
              </div>

              <!-- Info -->
              <div class="p-6">
                <h2 class="font-display font-black text-xl text-bg-dark mb-1">{member.data.name}</h2>
                <p class="text-gold font-semibold text-sm mb-4">{member.data.role}</p>
                <div class="prose prose-sm prose-gray max-w-none text-gray-600 leading-relaxed">
                  <member.rendered.Content />
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <p class="text-gray-400">Team profiles coming soon.</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-bg-dark text-white text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="font-display font-bold text-3xl mb-4">Work With Us</h2>
      <p class="text-gray-400 mb-8">Whether you're buying land or looking to sell — we'd love to hear from you.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/listings" class="bg-gold text-bg-dark font-bold px-8 py-4 rounded-2xl hover:bg-yellow-400 transition-colors">
          Browse Listings
        </a>
        <a href="/contact" class="border-2 border-white text-white font-bold px-8 py-4 rounded-2xl hover:bg-white/10 transition-colors">
          Get In Touch
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
