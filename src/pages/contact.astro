---
import BaseLayout from '../layouts/BaseLayout.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
import { siteConfig } from '../config/site.js';
import { getEntry } from 'astro:content';

const contactSettings = await getEntry('settings', 'contact');
const phone    = contactSettings?.data.phone    ?? siteConfig.phone;
const phoneRaw = contactSettings?.data.phoneRaw ?? siteConfig.phoneRaw;
const email    = contactSettings?.data.email    ?? siteConfig.email;
---

<BaseLayout
  title="Contact"
  description="Get in touch with Alot of Land LLC. Call, email, or fill out our contact form. We work in Arizona and Tennessee."
  noChat={true}
>
  <div class="bg-bg-dark text-white py-14">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-display font-black text-4xl sm:text-5xl mb-3">Get In Touch</h1>
      <p class="text-gray-400 text-lg">We'd love to hear from you — whether you're buying, selling, or just curious.</p>
    </div>
  </div>

  <!-- Testimonial above form -->
  <TestimonialSection variant="light" max={1} />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-2 gap-12">
      <!-- Left: Direct contact -->
      <div>
        <h2 class="font-display font-bold text-2xl text-bg-dark mb-8">Reach Us Directly</h2>

        <div class="space-y-6 mb-10">
          <a
            href={`tel:${phoneRaw}`}
            class="flex items-center gap-4 bg-gold text-bg-dark font-bold text-lg px-6 py-5 rounded-2xl hover:bg-yellow-400 transition-colors"
          >
            <span class="text-3xl">📞</span>
            <div>
              <div class="text-xs font-semibold uppercase tracking-wider opacity-70 mb-0.5">Call or Text</div>
              <div>{phone}</div>
            </div>
          </a>

          <a
            href={`mailto:${email}`}
            class="flex items-center gap-4 bg-white border border-gray-100 shadow-sm text-bg-dark font-bold text-lg px-6 py-5 rounded-2xl hover:shadow-md transition-shadow"
          >
            <span class="text-3xl">✉️</span>
            <div>
              <div class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-0.5">Email</div>
              <div>{email}</div>
            </div>
          </a>
        </div>

        <div class="bg-bg-light rounded-2xl p-6 border border-gray-100">
          <h3 class="font-semibold text-bg-dark mb-3">Active Markets</h3>
          <div class="flex flex-wrap gap-2">
            {['🌵 Arizona', '🏞️ Tennessee'].map(s => (
              <span class="bg-white border border-gray-200 rounded-full px-4 py-1.5 text-sm font-medium">{s}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: General form -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
        <h2 class="font-display font-bold text-2xl text-bg-dark mb-6">Send a Message</h2>

        <iframe
          src="https://brand.alot.land/widget/form/jEgrVqG5jxShya9tdQtw"
          style="width:100%;height:1074px;border:none;border-radius:8px"
          id="inline-jEgrVqG5jxShya9tdQtw"
          data-layout="{'id':'INLINE'}"
          data-trigger-type="alwaysShow"
          data-trigger-value=""
          data-activation-type="alwaysActivated"
          data-activation-value=""
          data-deactivation-type="neverDeactivate"
          data-deactivation-value=""
          data-form-name="Contact"
          data-height="1132"
          data-layout-iframe-id="inline-jEgrVqG5jxShya9tdQtw"
          data-form-id="jEgrVqG5jxShya9tdQtw"
          title="Contact"
        ></iframe>
        <script src="https://brand.alot.land/js/form_embed.js"></script>
      </div>
    </div>
  </div>
</BaseLayout>

