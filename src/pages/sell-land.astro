---
import BaseLayout from '../layouts/BaseLayout.astro';
import TestimonialSection from '../components/TestimonialSection.astro';
---

<BaseLayout
  title="Sell Your Land Fast — Get a Cash Offer"
  description="Get a fast, fair cash offer on your land. Fill out our quick form and we'll be in touch within 1 business day."
  noChat={true}
>
  <!-- Hero -->
  <div class="bg-bg-dark text-white py-14">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block bg-gold/20 text-gold text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full mb-4">No Obligation</span>
      <h1 class="font-display font-black text-4xl sm:text-5xl mb-4">Get a Cash Offer on Your Land</h1>
      <p class="text-gray-400 text-lg max-w-xl mx-auto">
        We buy land in Arizona and Tennessee. Fast closings, no commissions, no hassle. Fill out the form below and we'll get back to you within 1 business day.
      </p>
      <div class="flex flex-wrap justify-center gap-6 mt-8 text-sm text-gray-400">
        <span class="flex items-center gap-2"><span class="text-gold">✓</span> No agent fees</span>
        <span class="flex items-center gap-2"><span class="text-gold">✓</span> Close in as little as 2 weeks</span>
        <span class="flex items-center gap-2"><span class="text-gold">✓</span> We buy as-is</span>
      </div>
    </div>
  </div>

  <!-- Reassurance band -->
  <div class="bg-bg-light border-b border-gray-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid sm:grid-cols-3 gap-8 text-center">
        {[
          { icon: '📊', title: 'A Fair Offer — Not a Lowball', desc: 'Every offer is based on recent comparable sales in your area. We tell you how we got there.' },
          { icon: '🤝', title: 'David Reviews It Personally', desc: 'You deal directly with David — no call centers, no middlemen, no pressure.' },
          { icon: '⚡', title: 'Cash, Closed Fast', desc: 'No agent fees, no commissions. We buy as-is and can close in as little as 2 weeks.' },
        ].map(item => (
          <div>
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-display font-bold text-bg-dark mb-2">{item.title}</h3>
            <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Testimonial -->
  <TestimonialSection variant="light" max={1} />

  <!-- Form -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <h2 class="font-display font-black text-2xl sm:text-3xl text-bg-dark text-center mb-3">Get Your Free Cash Offer</h2>
    <p class="text-gray-500 text-center mb-8 max-w-xl mx-auto">Tell us about your land below. There's no obligation — if the offer isn't right for you, no problem.</p>
    <iframe
      src="https://brand.alot.land/widget/form/5nUi108ccuZMBuvv27Zd"
      style="width:100%;height:2316px;border:none;border-radius:8px"
      id="inline-5nUi108ccuZMBuvv27Zd"
      data-layout="{'id':'INLINE'}"
      data-trigger-type="alwaysShow"
      data-trigger-value=""
      data-activation-type="alwaysActivated"
      data-activation-value=""
      data-deactivation-type="neverDeactivate"
      data-deactivation-value=""
      data-form-name="Sell Your Land - Cash Offer Request"
      data-height="2316"
      data-layout-iframe-id="inline-5nUi108ccuZMBuvv27Zd"
      data-form-id="5nUi108ccuZMBuvv27Zd"
      title="Sell Your Land - Cash Offer Request"
    ></iframe>
    <script src="https://brand.alot.land/js/form_embed.js"></script>
  </div>


</BaseLayout>

