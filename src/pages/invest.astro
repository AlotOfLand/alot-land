---
import BaseLayout from '../layouts/BaseLayout.astro';
import MailerLiteForm from '../components/MailerLiteForm.astro';
---

<BaseLayout
  title="Invest With Us"
  description="Partner with A Lot of Land LLC as a private investor. We find undervalued land, subdivide it, and sell the parcels. Deal-by-deal private funding."
>
  <!-- Hero -->
  <div class="relative bg-bg-dark text-white overflow-hidden">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center relative z-10">
      <h1 class="font-display font-black text-5xl sm:text-6xl mb-6">
        Put Your Capital to Work in Land
      </h1>
      <p class="text-gray-300 text-xl leading-relaxed max-w-2xl mx-auto">
        We find undervalued land, fund it with private capital, subdivide it, and sell the new parcels. Simple model. Real assets.
      </p>
    </div>
  </div>

  <!-- Section 1: Private Lending -->
  <section class="py-20 bg-bg-light">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-green-brand font-bold text-sm uppercase tracking-wider">Private Funding</span>
          <h2 class="font-display font-bold text-3xl sm:text-4xl text-bg-dark mt-2 mb-5">
            Deal-by-Deal Private Funding
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            We work with a select group of private investors who participate in individual deals on a deal-by-deal basis. Each deal is secured by real estate.
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            If you're curious about how we structure our projects and whether there's a fit, we'd love to have a conversation. No commitment required — just a conversation.
          </p>
          <a href="#investor-form" class="bg-green-brand text-white font-bold px-6 py-3 rounded-xl hover:opacity-90 transition-opacity inline-block">
            Start the Conversation
          </a>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
          <h3 class="font-display font-bold text-xl text-bg-dark mb-6">How It Works</h3>
          <ol class="space-y-5">
            {[
              { n: '1', title: 'We identify a land opportunity', desc: 'We find an undervalued parcel with subdivision potential through direct outreach to landowners.' },
              { n: '2', title: 'We bring in private funders', desc: 'We work with private investors to fund the acquisition and subdivision costs.' },
              { n: '3', title: 'We subdivide & sell', desc: 'We divide the parcel into individual lots and list them on the market.' },
              { n: '4', title: 'Funders are repaid', desc: 'After sale, funders are repaid their principal plus their agreed return.' },
            ].map(step => (
              <li class="flex gap-4">
                <div class="w-8 h-8 bg-green-brand text-white rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0">
                  {step.n}
                </div>
                <div>
                  <p class="font-semibold text-bg-dark text-sm">{step.title}</p>
                  <p class="text-gray-500 text-sm mt-0.5">{step.desc}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Subdivide Model -->
  <section class="py-20 bg-bg-dark text-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-display font-bold text-3xl sm:text-4xl mb-4">The Subdivide Model</h2>
        <p class="text-gray-400 text-lg">A straightforward strategy built on land.</p>
      </div>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 flex-wrap">
        {[
          { icon: '🔍', label: 'Find It', desc: 'Identify undervalued land through direct outreach' },
          { icon: '→', arrow: true },
          { icon: '💼', label: 'Fund It', desc: 'Bring in private capital secured by real estate' },
          { icon: '→', arrow: true },
          { icon: '✂️', label: 'Subdivide It', desc: 'Minor subdivide creates multiple new parcels' },
          { icon: '→', arrow: true },
          { icon: '📋', label: 'Sell It', desc: 'List new lots on-market with top land realtors' },
        ].map(item => (
          item.arrow
            ? <span class="text-gold text-2xl font-bold hidden sm:block">{item.icon}</span>
            : (
              <div class="bg-[#111] rounded-2xl p-6 text-center flex-1 min-w-[140px] border border-[#222]">
                <div class="text-3xl mb-3">{item.icon}</div>
                <div class="font-display font-bold text-gold mb-1">{item.label}</div>
                <div class="text-gray-500 text-xs leading-snug">{item.desc}</div>
              </div>
            )
        ))}
      </div>

      <div class="mt-10 bg-[#111] rounded-2xl p-6 border border-[#222]">
        <p class="text-gray-400 text-sm leading-relaxed text-center">
          We currently execute this model in <strong class="text-white">Tennessee</strong>, where minor subdivides are a proven, efficient strategy. We use direct-mail sourcing to find the land, private capital to fund it, and top local land agents to sell the new parcels.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 3: Free Investor Guide -->
  <section class="py-20 bg-bg-light">
    <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-green-brand font-bold text-sm uppercase tracking-wider">Free Resource</span>
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-bg-dark mt-2 mb-4">Get the Free Passive Land Investing Guide</h2>
      <p class="text-gray-600 leading-relaxed mb-8">
        Curious how land investing works without buying or managing land yourself? Download our free guide — no commitment required.
      </p>
      <MailerLiteForm
        containerId="mlb2-40807480"
        formAction="https://assets.mailerlite.com/jsonp/2316201/forms/186552180887521130/subscribe"
        title="Free Passive Land Investing Guide"
        description="Learn how to earn passive income from land without the hassle of buying, managing, or developing it yourself."
        successMessage="Check your email for your free <em>Passive Land Investing</em> guide!"
      />
    </div>
  </section>

  <!-- Investor Inquiry Form -->
  <section id="investor-form" class="py-20 bg-bg-dark text-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="font-display font-bold text-3xl sm:text-4xl mb-3">I'm Interested — Let's Talk</h2>
        <p class="text-gray-400">Fill out the form below and we'll reach out to schedule a conversation.</p>
      </div>

      <div class="bg-[#111] rounded-2xl border border-[#222] p-8">
        <form
          name="investor-inquiry"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          id="investor-inquiry-form"
          class="space-y-5"
        >
          <input type="hidden" name="form-name" value="investor-inquiry" />
          <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-300 mb-1.5">First Name *</label>
              <input type="text" name="first-name" required class="w-full bg-bg-dark border border-[#333] rounded-xl px-4 py-2.5 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-green-brand" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-300 mb-1.5">Last Name *</label>
              <input type="text" name="last-name" required class="w-full bg-bg-dark border border-[#333] rounded-xl px-4 py-2.5 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-green-brand" />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-gray-300 mb-1.5">Phone *</label>
              <input type="tel" name="phone" required class="w-full bg-bg-dark border border-[#333] rounded-xl px-4 py-2.5 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-green-brand" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-300 mb-1.5">Email *</label>
              <input type="email" name="email" required class="w-full bg-bg-dark border border-[#333] rounded-xl px-4 py-2.5 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-green-brand" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-300 mb-1.5">Approximate Capital Available</label>
            <select name="capital" class="w-full bg-bg-dark border border-[#333] rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:ring-2 focus:ring-green-brand">
              <option value="">Select a range...</option>
              <option>Under $25K</option>
              <option>$25K–$100K</option>
              <option>$100K–$250K</option>
              <option>$250K–$500K</option>
              <option>$500K+</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-300 mb-1.5">What are your investment goals?</label>
            <textarea name="goals" rows="3" class="w-full bg-bg-dark border border-[#333] rounded-xl px-4 py-2.5 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-green-brand resize-none"></textarea>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-300 mb-1.5">How did you hear about us?</label>
            <input type="text" name="referral" class="w-full bg-bg-dark border border-[#333] rounded-xl px-4 py-2.5 text-sm text-white placeholder-gray-600 focus:outline-none focus:ring-2 focus:ring-green-brand" />
          </div>

          <button type="submit" class="w-full bg-green-brand text-white font-bold py-4 rounded-2xl hover:opacity-90 transition-opacity">
            I'm Interested — Let's Talk
          </button>
        </form>

        <div id="investor-inquiry-thanks" class="hidden text-center py-8">
          <div class="text-4xl mb-4">🤝</div>
          <h3 class="font-display font-bold text-xl text-white mb-2">Thanks for reaching out!</h3>
          <p class="text-gray-400">We'll be in touch within 1–2 business days to schedule a conversation.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Investor inquiry form
  const inquiryForm = document.getElementById('investor-inquiry-form') as HTMLFormElement;
  const inquiryThanks = document.getElementById('investor-inquiry-thanks');
  inquiryForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(inquiryForm);
    await fetch('/', { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: new URLSearchParams(data as any).toString() });
    inquiryForm.classList.add('hidden');
    inquiryThanks?.classList.remove('hidden');
  });
</script>
