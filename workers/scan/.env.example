# Copy to .env and chmod 600. Load with:  set -a; source .env; set +a
# SERVICE ROLE key: Supabase Dashboard -> Project Settings -> API -> service_role.
# This key bypasses RLS - it lives ONLY here and on the droplet. Never in the
# web app, never committed.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
# Optional: only needed if more than one org exists.
# MFDA_ORG_ID=
